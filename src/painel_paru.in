#!/usr/bin/env @PYTHON@
import sys
import os

# Configuração crítica para encontrar o módulo
print("🔍 Procurando diretório do módulo...")
bin_dir = os.path.dirname(os.path.abspath(__file__))
print(f" - Diretório do executável: {bin_dir}")

# Possíveis locais onde o pacote painel_paru pode estar
possible_locations = [
    # Diretório principal de dados (após instalação)
    os.path.join(bin_dir, '../share/painel_paru'),
    '/app/share/painel_paru',
    os.path.join(sys.prefix, 'share/painel_paru'),
    # Local de desenvolvimento (dentro do src)
    os.path.join(os.path.dirname(bin_dir), 'src'),
    # Local de desenvolvimento (diretório raiz do projeto)
    os.path.join(os.path.dirname(os.path.dirname(bin_dir)), 'src')
]

module_dir = None
for location in possible_locations:
    # Verifica se o pacote painel_paru existe neste local
    if os.path.exists(os.path.join(location, 'painel_paru', '__init__.py')):
        module_dir = location
        break

if not module_dir:
    print("❌ Diretório do módulo não encontrado em nenhum local conhecido")
    print("Locais verificados:")
    for loc in possible_locations:
        print(f" - {loc}")
    sys.exit(1)

# Adiciona ao PYTHONPATH
if module_dir not in sys.path:
    print(f"✅ Adicionando ao PYTHONPATH: {module_dir}")
    sys.path.insert(0, module_dir)

# Diagnóstico adicional
print("📁 Conteúdo do diretório adicionado:")
if os.path.exists(module_dir):
    for item in os.listdir(module_dir):
        print(f" - {item}")
    if os.path.exists(os.path.join(module_dir, 'painel_paru')):
        print("\n📁 Conteúdo do pacote painel_paru:")
        for item in os.listdir(os.path.join(module_dir, 'painel_paru')):
            print(f" - {item}")

# Importa e executa a função principal
try:
    print("🔄 Tentando importar painel_paru.main...")
    from painel_paru.main import app_main
    print("✅ Import bem-sucedido!")
    app_main('@VERSION@')
except Exception as e:
    print(f"❌ Erro FATAL ao importar: {str(e)}")
    import traceback
    traceback.print_exc()
    sys.stderr.write(f"Erro ao iniciar aplicação: {e}")
    sys.exit(1)
