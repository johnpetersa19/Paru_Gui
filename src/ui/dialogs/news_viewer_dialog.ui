<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.5"/>
  <object class="AdwDialog" id="NewsViewerDialog">
    <property name="title" translatable="yes">Arch Linux News</property>
    <property name="content-width">1000</property>
    <property name="content-height">750</property>
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start">
              <object class="GtkBox" id="navigation_header">
                <property name="orientation">horizontal</property>
                <property name="spacing">8</property>
                <property name="valign">center</property>
                <child>
                  <object class="GtkButton" id="back_to_news_list_button">
                    <property name="icon-name">go-previous-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Back to News List</property>
                    <signal name="clicked" handler="on_back_to_news_list_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_label">
                    <property name="label" translatable="yes">Main › Arch News › Select Article</property>
                    <property name="ellipsize">end</property>
                    <property name="max-width-chars">50</property>
                    <style>
                      <class name="caption"/>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
            <property name="title-widget">
              <object class="AdwWindowTitle">
                <property name="title" translatable="yes">Arch Linux News</property>
                <property name="subtitle" translatable="yes">Latest news and announcements</property>
              </object>
            </property>
            <child type="end">
              <object class="GtkBox" id="header_actions">
                <property name="spacing">4</property>
                <child>
                  <object class="GtkButton" id="mark_all_read_button">
                    <property name="icon-name">object-select-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Mark All Articles as Read</property>
                    <signal name="clicked" handler="on_mark_all_read_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="refresh_button">
                    <property name="icon-name">view-refresh-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Refresh News Feed</property>
                    <signal name="clicked" handler="on_refresh_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwToastOverlay" id="toast_overlay">
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">0</property>
                <child>
                  <object class="GtkSearchBar" id="search_bar">
                    <property name="search-mode-enabled">False</property>
                    <child>
                      <object class="GtkSearchEntry" id="search_entry">
                        <property name="placeholder-text" translatable="yes">Search news articles...</property>
                        <property name="hexpand">True</property>
                        <signal name="search-changed" handler="on_search_changed"/>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">0</property>
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="width-request">320</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="margin-top">16</property>
                            <property name="margin-start">16</property>
                            <property name="margin-end">8</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">News Articles</property>
                                <property name="hexpand">True</property>
                                <property name="halign">start</property>
                                <style>
                                  <class name="title-3"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="article_count_label">
                                <property name="label" translatable="yes">0 articles</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkToggleButton" id="search_toggle">
                                <property name="icon-name">edit-find-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Search Articles</property>
                                <signal name="toggled" handler="on_search_toggled"/>
                                <style>
                                  <class name="flat"/>
                                  <class name="circular"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScrolledWindow" id="news_scroll">
                            <property name="vexpand">True</property>
                            <property name="hscrollbar-policy">never</property>
                            <property name="margin-start">16</property>
                            <property name="margin-end">8</property>
                            <property name="margin-bottom">16</property>
                            <child>
                              <object class="GtkListBox" id="news_listbox">
                                <property name="selection-mode">single</property>
                                <signal name="row-selected" handler="on_news_selected"/>
                                <style>
                                  <class name="boxed-list"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">vertical</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">0</property>
                        <property name="hexpand">True</property>
                        <child>
                          <object class="GtkBox" id="article_header">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <property name="margin-top">16</property>
                            <property name="margin-start">16</property>
                            <property name="margin-end">16</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="article_title">
                                    <property name="label" translatable="yes">Select an article to read</property>
                                    <property name="hexpand">True</property>
                                    <property name="halign">start</property>
                                    <property name="wrap">True</property>
                                    <property name="wrap-mode">word-char</property>
                                    <property name="max-width-chars">60</property>
                                    <style>
                                      <class name="title-2"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="article_actions">
                                    <property name="spacing">4</property>
                                    <child>
                                      <object class="GtkButton" id="mark_read_button">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <property name="tooltip-text" translatable="yes">Mark Article as Read</property>
                                        <property name="sensitive">False</property>
                                        <signal name="clicked" handler="on_mark_read_clicked"/>
                                        <style>
                                          <class name="flat"/>
                                          <class name="circular"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkMenuButton" id="share_menu_button">
                                        <property name="icon-name">emblem-shared-symbolic</property>
                                        <property name="tooltip-text" translatable="yes">Share or Export Article</property>
                                        <property name="sensitive">False</property>
                                        <style>
                                          <class name="flat"/>
                                          <class name="circular"/>
                                        </style>
                                        <property name="popover">
                                          <object class="GtkPopover">
                                            <property name="position">bottom</property>
                                            <child>
                                              <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="spacing">8</property>
                                                <property name="margin-top">12</property>
                                                <property name="margin-bottom">12</property>
                                                <property name="margin-start">12</property>
                                                <property name="margin-end">12</property>
                                                <child>
                                                  <object class="GtkButton" id="copy_link_button">
                                                    <property name="label" translatable="yes">Copy Link</property>
                                                    <property name="tooltip-text" translatable="yes">Copy article URL to clipboard</property>
                                                    <signal name="clicked" handler="on_copy_link_clicked"/>
                                                    <style>
                                                      <class name="flat"/>
                                                    </style>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkButton" id="export_text_button">
                                                    <property name="label" translatable="yes">Export as Text</property>
                                                    <property name="tooltip-text" translatable="yes">Save article content as text file</property>
                                                    <signal name="clicked" handler="on_export_text_clicked"/>
                                                    <style>
                                                      <class name="flat"/>
                                                    </style>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkButton" id="export_pdf_button">
                                                    <property name="label" translatable="yes">Export as PDF</property>
                                                    <property name="tooltip-text" translatable="yes">Save article as PDF document</property>
                                                    <signal name="clicked" handler="on_export_pdf_clicked"/>
                                                    <style>
                                                      <class name="flat"/>
                                                    </style>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="open_browser_button">
                                        <property name="icon-name">web-browser-symbolic</property>
                                        <property name="tooltip-text" translatable="yes">Open Article in Browser</property>
                                        <property name="sensitive">False</property>
                                        <signal name="clicked" handler="on_open_browser_clicked"/>
                                        <style>
                                          <class name="flat"/>
                                          <class name="circular"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">16</property>
                                <child>
                                  <object class="GtkLabel" id="article_date">
                                    <property name="label" translatable="yes"></property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="article_author">
                                    <property name="label" translatable="yes"></property>
                                    <property name="hexpand">True</property>
                                    <property name="halign">center</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="read_status_label">
                                    <property name="label" translatable="yes"></property>
                                    <property name="halign">end</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="accent"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="navigation_controls">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">8</property>
                                <property name="halign">center</property>
                                <property name="margin-top">8</property>
                                <child>
                                  <object class="GtkButton" id="previous_article_button">
                                    <property name="label" translatable="yes">Previous Article</property>
                                    <property name="tooltip-text" translatable="yes">Navigate to previous article</property>
                                    <property name="sensitive">False</property>
                                    <signal name="clicked" handler="on_previous_article_clicked"/>
                                    <style>
                                      <class name="pill"/>
                                    </style>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">6</property>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">go-previous-symbolic</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Previous</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="article_position_label">
                                    <property name="label" translatable="yes">-- / --</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="next_article_button">
                                    <property name="label" translatable="yes">Next Article</property>
                                    <property name="tooltip-text" translatable="yes">Navigate to next article</property>
                                    <property name="sensitive">False</property>
                                    <signal name="clicked" handler="on_next_article_clicked"/>
                                    <style>
                                      <class name="pill"/>
                                    </style>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">6</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Next</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">go-next-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSeparator">
                            <property name="margin-start">16</property>
                            <property name="margin-end">16</property>
                            <property name="margin-top">8</property>
                            <property name="margin-bottom">8</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScrolledWindow" id="content_scroll">
                            <property name="vexpand">True</property>
                            <property name="margin-start">16</property>
                            <property name="margin-end">16</property>
                            <property name="margin-bottom">16</property>
                            <child>
                              <object class="GtkTextView" id="content_textview">
                                <property name="editable">False</property>
                                <property name="cursor-visible">False</property>
                                <property name="wrap-mode">word</property>
                                <property name="left-margin">16</property>
                                <property name="right-margin">16</property>
                                <property name="top-margin">16</property>
                                <property name="bottom-margin">16</property>
                                <style>
                                  <class name="card"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkRevealer" id="progress_revealer">
                    <property name="reveal-child">false</property>
                    <property name="transition-type">slide-down</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin-top">8</property>
                        <property name="margin-bottom">8</property>
                        <property name="margin-start">16</property>
                        <property name="margin-end">16</property>
                        <child>
                          <object class="GtkProgressBar" id="progress_bar">
                            <property name="show-text">true</property>
                            <style>
                              <class name="osd"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="progress_detail_label">
                            <property name="label" translatable="yes">Loading news articles...</property>
                            <property name="halign">center</property>
                            <style>
                              <class name="caption"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
        <child type="bottom">
          <object class="GtkActionBar">
            <child type="start">
              <object class="GtkButton" id="news_list_button">
                <property name="label" translatable="yes">Back to News List</property>
                <property name="tooltip-text" translatable="yes">Return to main news list</property>
                <signal name="clicked" handler="on_back_to_news_list_clicked"/>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="status_label">
                <property name="label" translatable="yes">Ready</property>
                <style>
                  <class name="caption"/>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
            <child type="end">
              <object class="GtkBox" id="bottom_actions">
                <property name="spacing">8</property>
                <child>
                  <object class="GtkButton" id="mark_read_footer_button">
                    <property name="label" translatable="yes">Mark as Read</property>
                    <property name="tooltip-text" translatable="yes">Mark current article as read</property>
                    <property name="sensitive">False</property>
                    <signal name="clicked" handler="on_mark_read_clicked"/>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="close_button">
                    <property name="label" translatable="yes">Close</property>
                    <signal name="clicked" handler="on_close_clicked"/>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
