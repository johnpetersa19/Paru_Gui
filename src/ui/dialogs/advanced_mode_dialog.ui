<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.10"/>
  <requires lib="libadwaita" version="1.4"/>

  <object class="AdwDialog" id="advanced_mode_dialog">
    <property name="content-height">700</property>
    <property name="content-width">900</property>
    <property name="title" translatable="yes">Advanced Mode</property>

    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="AdwViewSwitcher">
                <property name="stack">advanced_notebook</property>
                <property name="policy">wide</property>
              </object>
            </property>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>

        <child>
          <object class="GtkBox" id="navigation_header">
            <property name="margin-end">24</property>
            <property name="margin-start">24</property>
            <property name="margin-top">18</property>
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>

            <child>
              <object class="GtkBox" id="breadcrumb_box">
                <property name="spacing">6</property>
                <child>
                  <object class="GtkButton" id="breadcrumb_main">
                    <property name="label" translatable="yes">Main</property>
                    <property name="tooltip-text" translatable="yes">Return to main view</property>
                    <style>
                      <class name="flat"/>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="breadcrumb_content">
                    <property name="label" translatable="yes">Content</property>
                    <property name="tooltip-text" translatable="yes">Return to content management</property>
                    <style>
                      <class name="flat"/>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Advanced Mode</property>
                    <style>
                      <class name="caption"/>
                      <class name="accent"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkBox" id="mode_selector_box">
                <property name="spacing">12</property>
                <child>
                  <object class="GtkBox">
                    <property name="hexpand">true</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkBox">
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkImage">
                            <property name="halign">center</property>
                            <property name="icon-name">applications-system-symbolic</property>
                            <property name="pixel-size">32</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="accent"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="hexpand">true</property>
                            <property name="orientation">vertical</property>
                            <property name="spacing">3</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Advanced Mode</property>
                                <style>
                                  <class name="title-2"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Execute custom commands, debug operations, and view system information</property>
                                <property name="wrap">true</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="mode_toggle_box">
                        <property name="spacing">6</property>
                        <child>
                          <object class="GtkToggleButton" id="guided_mode_toggle">
                            <property name="active">true</property>
                            <property name="label" translatable="yes">Guided Mode</property>
                            <property name="tooltip-text" translatable="yes">Step-by-step guidance with explanations</property>
                            <style>
                              <class name="pill"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkToggleButton" id="expert_mode_toggle">
                            <property name="group">guided_mode_toggle</property>
                            <property name="label" translatable="yes">Expert Mode</property>
                            <property name="tooltip-text" translatable="yes">Direct access to all features without guidance</property>
                            <style>
                              <class name="pill"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="return_simple_mode_button">
                    <property name="label" translatable="yes">Return to Simple Mode</property>
                    <property name="tooltip-text" translatable="yes">Exit advanced mode and return to simple interface</property>
                    <style>
                      <class name="destructive-action"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkSeparator">
            <property name="margin-bottom">12</property>
            <property name="margin-end">24</property>
            <property name="margin-start">24</property>
            <property name="margin-top">12</property>
          </object>
        </child>

        <child>
          <object class="AdwViewStack" id="advanced_notebook">
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>

            <child>
              <object class="AdwViewStackPage">
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkBox" id="custom_command_tab">
                        <property name="margin-bottom">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-top">24</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">18</property>

                        <child>
                          <object class="GtkBox" id="difficulty_indicator_commands">
                            <property name="spacing">6</property>
                            <child>
                              <object class="GtkImage">
                                <property name="icon-name">security-high-symbolic</property>
                                <property name="pixel-size">16</property>
                                <style>
                                  <class name="warning"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">High Risk - Advanced Users Only</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="warning"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Custom Command</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkEntry" id="command_entry">
                                    <property name="placeholder-text" translatable="yes">Enter paru command (e.g., paru -S package-name)</property>
                                    <property name="width-request">400</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Enter any paru command. Common examples: -S (install), -R (remove), -Ss (search), -Syu (update)</property>
                                    <property name="wrap">true</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Execution Options</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid" id="command_options_grid">
                                <property name="column-spacing">12</property>
                                <property name="row-spacing">12</property>
                                <child>
                                  <object class="GtkCheckButton" id="dry_run_check">
                                    <property name="label" translatable="yes">Dry run (--dry-run)</property>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkCheckButton" id="verbose_check">
                                    <property name="label" translatable="yes">Verbose output (--verbose)</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkCheckButton" id="no_confirm_check">
                                    <property name="label" translatable="yes">No confirmation (--noconfirm)</property>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkCheckButton" id="force_check">
                                    <property name="label" translatable="yes">Force operation (--force)</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Working Directory</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkEntry" id="working_dir_entry">
                                    <property name="hexpand">true</property>
                                    <property name="placeholder-text" translatable="yes">/path/to/working/directory</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="browse_dir_button">
                                    <property name="icon-name">folder-symbolic</property>
                                    <property name="tooltip-text" translatable="yes">Browse for directory</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkRevealer" id="progress_revealer_commands">
                            <property name="reveal-child">false</property>
                            <child>
                              <object class="GtkBox">
                                <property name="halign">center</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkSpinner" id="command_spinner">
                                    <property name="spinning">true</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Executing command...</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="halign">center</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkButton" id="validate_command_button">
                                <property name="label" translatable="yes">Validate Command</property>
                                <property name="tooltip-text" translatable="yes">Check command syntax before execution</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="execute_command_button">
                                <property name="label" translatable="yes">Execute Command</property>
                                <property name="tooltip-text" translatable="yes">Run the custom paru command</property>
                                <style>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                      </object>
                    </child>
                  </object>
                </property>
                <property name="name">custom_command</property>
                <property name="title" translatable="yes">Custom Command</property>
                <property name="icon-name">utilities-terminal-symbolic</property>
              </object>
            </child>

            <child>
              <object class="AdwViewStackPage">
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkBox" id="system_info_tab">
                        <property name="margin-bottom">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-top">24</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">18</property>

                        <child>
                          <object class="GtkBox" id="difficulty_indicator_system">
                            <property name="spacing">6</property>
                            <child>
                              <object class="GtkImage">
                                <property name="icon-name">security-low-symbolic</property>
                                <property name="pixel-size">16</property>
                                <style>
                                  <class name="success"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Safe - Read-Only Information</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="success"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label" translatable="yes">System Information</property>
                                    <style>
                                      <class name="heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="refresh_system_info_button">
                                    <property name="icon-name">view-refresh-symbolic</property>
                                    <property name="tooltip-text" translatable="yes">Refresh system information</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid" id="system_info_grid">
                                <property name="column-spacing">24</property>
                                <property name="row-spacing">12</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Paru Version:</property>
                                    <property name="width-request">150</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="paru_version_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">--</property>
                                    <property name="selectable">true</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Pacman Version:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="pacman_version_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">--</property>
                                    <property name="selectable">true</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">AUR Helper:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">2</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="aur_helper_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">paru</property>
                                    <property name="selectable">true</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">2</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Cache Directory:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">3</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="cache_dir_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">~/.cache/paru</property>
                                    <property name="selectable">true</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">3</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Build Directory:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">4</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="build_dir_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">~/.cache/paru/clone</property>
                                    <property name="selectable">true</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">4</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Configuration Status</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid" id="config_status_grid">
                                <property name="column-spacing">24</property>
                                <property name="row-spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkImage" id="config_valid_icon">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <style>
                                          <class name="success"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Configuration Valid</property>
                                      </object>
                                    </child>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkImage" id="aur_access_icon">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <style>
                                          <class name="success"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">AUR Access</property>
                                      </object>
                                    </child>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkImage" id="git_available_icon">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <style>
                                          <class name="success"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Git Available</property>
                                      </object>
                                    </child>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkImage" id="makepkg_available_icon">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <style>
                                          <class name="success"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Makepkg Available</property>
                                      </object>
                                    </child>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">System Resources</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid" id="resources_grid">
                                <property name="column-spacing">24</property>
                                <property name="row-spacing">12</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Available Disk Space:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="disk_space_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">--</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Memory Usage:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="memory_usage_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">--</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">CPU Cores:</property>
                                    <style>
                                      <class name="caption"/>
                                    </style>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">2</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="cpu_cores_label">
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="label">--</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">2</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="halign">center</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkButton" id="open_config_button">
                                <property name="label" translatable="yes">Open Configuration</property>
                                <property name="tooltip-text" translatable="yes">Open paru configuration file in editor</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="open_logs_button">
                                <property name="label" translatable="yes">View Logs</property>
                                <property name="tooltip-text" translatable="yes">View system and paru operation logs</property>
                              </object>
                            </child>
                          </object>
                        </child>

                      </object>
                    </child>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkBox">
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">computer-symbolic</property>
                        <property name="pixel-size">16</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">System Info</property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

          </object>
        </child>

        <child>
          <object class="GtkBox" id="output_section">
            <property name="margin-bottom">18</property>
            <property name="margin-end">24</property>
            <property name="margin-start">24</property>
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkBox">
                <property name="spacing">12</property>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="hexpand">true</property>
                    <property name="label" translatable="yes">Real-time Output</property>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="clear_output_button">
                    <property name="icon-name">edit-clear-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Clear output</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="save_output_button">
                    <property name="icon-name">document-save-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Save output to file</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow">
                <property name="height-request">200</property>
                <property name="vexpand">true</property>
                <child>
                  <object class="GtkTextView" id="output_textview">
                    <property name="editable">false</property>
                    <property name="monospace">true</property>
                    <property name="wrap-mode">word</property>
                    <style>
                      <class name="card"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

          </object>
        </property>
      </object>
    </property>

  </object>

</interface>
