<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.14"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="AdvancedModeDialog" parent="AdwDialog">
    <property name="content-height">700</property>
    <property name="content-width">900</property>
    <property name="title" translatable="yes">Advanced Mode</property>

    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="AdwViewSwitcher">
                <property name="stack">advanced_notebook</property>
                <property name="policy">wide</property>
              </object>
            </property>
          </object>
        </child>

        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">0</property>

            <child>
              <object class="AdwViewStack" id="advanced_notebook">
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>

                <!-- Custom Command Page -->
                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">custom_command</property>
                    <property name="title" translatable="yes">Custom Command</property>
                    <property name="icon-name">utilities-terminal-symbolic</property>
                    <property name="child">
                      <object class="AdwPreferencesPage">
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Custom Command</property>
                            <property name="description" translatable="yes">High Risk - Advanced Users Only. Enter any paru command.</property>

                            <child>
                              <object class="AdwEntryRow" id="command_entry">
                                <property name="title" translatable="yes">Command</property>
                                <property name="text" translatable="yes">paru </property>
                              </object>
                            </child>

                            <child>
                              <object class="AdwEntryRow" id="working_dir_entry">
                                <property name="title" translatable="yes">Working Directory</property>
                                <child type="suffix">
                                  <object class="GtkButton" id="browse_dir_button">
                                    <property name="icon-name">folder-symbolic</property>
                                    <property name="valign">center</property>
                                    <style><class name="flat"/></style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Execution Options</property>
                            <child>
                              <object class="AdwSwitchRow" id="dry_run_check">
                                <property name="title" translatable="yes">Dry run (--dry-run)</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="verbose_check">
                                <property name="title" translatable="yes">Verbose output (--verbose)</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="no_confirm_check">
                                <property name="title" translatable="yes">No confirmation (--noconfirm)</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="force_check">
                                <property name="title" translatable="yes">Force operation (--force)</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">12</property>
                                <property name="halign">center</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <child>
                                  <object class="GtkButton" id="validate_command_button">
                                    <property name="label" translatable="yes">Validate Command</property>
                                    <style><class name="pill"/></style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="execute_command_button">
                                    <property name="label" translatable="yes">Execute Command</property>
                                    <style><class name="pill"/><class name="suggested-action"/></style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <!-- System Info Page -->
                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">system_info</property>
                    <property name="title" translatable="yes">System Info</property>
                    <property name="icon-name">computer-symbolic</property>
                    <property name="child">
                      <object class="AdwPreferencesPage">
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">System Information</property>
                            <property name="description" translatable="yes">Safe - Read-Only Information</property>
                            
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Paru Version</property>
                                <property name="subtitle" id="paru_version_label">--</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Pacman Version</property>
                                <property name="subtitle" id="pacman_version_label">--</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">AUR Helper</property>
                                <property name="subtitle" id="aur_helper_label">paru</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Cache Directory</property>
                                <property name="subtitle" id="cache_dir_label">~/.cache/paru</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Build Directory</property>
                                <property name="subtitle" id="build_dir_label">~/.cache/paru/clone</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Configuration Status</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Configuration Valid</property>
                                <child type="prefix">
                                  <object class="GtkImage" id="config_valid_icon"><property name="icon-name">emblem-ok-symbolic</property><style><class name="success"/></style></object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">AUR Access</property>
                                <child type="prefix">
                                  <object class="GtkImage" id="aur_access_icon"><property name="icon-name">emblem-ok-symbolic</property><style><class name="success"/></style></object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Git Available</property>
                                <child type="prefix">
                                  <object class="GtkImage" id="git_available_icon"><property name="icon-name">emblem-ok-symbolic</property><style><class name="success"/></style></object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Makepkg Available</property>
                                <child type="prefix">
                                  <object class="GtkImage" id="makepkg_available_icon"><property name="icon-name">emblem-ok-symbolic</property><style><class name="success"/></style></object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">System Resources</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Available Disk Space</property>
                                <property name="subtitle" id="disk_space_label">--</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Memory Usage</property>
                                <property name="subtitle" id="memory_usage_label">--</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">CPU Cores</property>
                                <property name="subtitle" id="cpu_cores_label">--</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        
                        <child>
                          <object class="AdwPreferencesGroup">
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">12</property>
                                <property name="halign">center</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <child>
                                  <object class="GtkButton" id="open_config_button">
                                    <property name="label" translatable="yes">Open Configuration</property>
                                    <style><class name="pill"/></style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="open_logs_button">
                                    <property name="label" translatable="yes">View Logs</property>
                                    <style><class name="pill"/></style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="refresh_system_info_button">
                                    <property name="label" translatable="yes">Refresh Info</property>
                                    <style><class name="pill"/></style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="GtkBox" id="output_section">
                <property name="margin-bottom">18</property>
                <property name="margin-end">24</property>
                <property name="margin-start">24</property>
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkBox">
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="hexpand">true</property>
                        <property name="label" translatable="yes">Real-time Output</property>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="clear_output_button">
                        <property name="icon-name">edit-clear-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Clear output</property>
                        <style><class name="flat"/><class name="circular"/></style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="save_output_button">
                        <property name="icon-name">document-save-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Save output to file</property>
                        <style><class name="flat"/><class name="circular"/></style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="height-request">200</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkTextView" id="output_textview">
                        <property name="editable">false</property>
                        <property name="monospace">true</property>
                        <property name="wrap-mode">word</property>
                        <style>
                          <class name="card"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

          </object>
        </property>
      </object>
    </property>

  </template>

</interface>
