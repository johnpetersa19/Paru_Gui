<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.5"/>

  <object class="AdwDialog" id="OrphanManagerDialog">
    <property name="title" translatable="yes">Orphan Package Manager</property>
    <property name="content-width">900</property>
    <property name="content-height">750</property>
    <property name="can-close">true</property>

    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">4</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Main</property>
                        <property name="css-classes">breadcrumb</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">›</property>
                        <property name="css-classes">breadcrumb-separator</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">System</property>
                        <property name="css-classes">breadcrumb</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">›</property>
                        <property name="css-classes">breadcrumb-separator</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Orphan Manager</property>
                        <property name="css-classes">breadcrumb-current</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Manage orphaned packages and installation reasons</property>
                    <property name="css-classes">subtitle</property>
                  </object>
                </child>
              </object>
            </property>
            <child type="start">
              <object class="GtkButton" id="back_button">
                <property name="icon-name">go-previous-symbolic</property>
                <property name="tooltip-text" translatable="yes">Back to System Tools</property>
                <signal name="clicked" handler="on_back_clicked"/>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton" id="actions_menu_button">
                <property name="icon-name">view-more-symbolic</property>
                <property name="tooltip-text" translatable="yes">Additional Actions</property>
                <property name="menu-model">orphan_actions_menu</property>
              </object>
            </child>
          </object>
        </child>

        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>

            <child>
              <object class="AdwBanner" id="operation_progress_banner">
                <property name="title" translatable="yes">Processing packages...</property>
                <property name="revealed">false</property>
                <property name="button-label" translatable="yes">Cancel</property>
                <property name="action-name">dialog.cancel-operation</property>
              </object>
            </child>

            <child>
              <object class="AdwViewSwitcher" id="view_switcher">
                <property name="stack">view_stack</property>
                <property name="policy">wide</property>
              </object>
            </child>

            <child>
              <object class="AdwViewStack" id="view_stack">
                <property name="vexpand">true</property>

                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">orphans</property>
                    <property name="title" translatable="yes">Orphaned Packages</property>
                    <property name="icon-name">user-trash-symbolic</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">What Are Orphaned Packages?</property>
                            <property name="description" translatable="yes">Understanding orphaned packages and why they occur</property>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Orphaned Package Definition</property>
                                <property name="subtitle" translatable="yes">Packages installed as dependencies but no longer needed by any explicitly installed package</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">dialog-information-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Why Do They Occur?</property>
                                <property name="subtitle" translatable="yes">When you remove a package, its dependencies may remain if not needed elsewhere</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">dialog-question-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Safe to Remove?</property>
                                <property name="subtitle" translatable="yes">Generally yes, but review the list carefully before removing packages</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">emblem-ok-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">start</property>

                            <child>
                              <object class="GtkButton" id="refresh_orphans_button">
                                <property name="label" translatable="yes">Refresh List</property>
                                <property name="icon-name">view-refresh-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Scan system for orphaned packages (paru -Qtdq)</property>
                                <signal name="clicked" handler="on_refresh_orphans_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="select_all_orphans_button">
                                <property name="label" translatable="yes">Select All</property>
                                <property name="icon-name">edit-select-all-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Select all orphaned packages for bulk operation</property>
                                <signal name="clicked" handler="on_select_all_orphans_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="create_orphans_list_button">
                                <property name="label" translatable="yes">Export List</property>
                                <property name="icon-name">document-save-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Export orphaned package list to file</property>
                                <signal name="clicked" handler="on_create_orphans_list_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="css-classes">card</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <property name="margin-top">12</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <child>
                                      <object class="GtkLabel" id="orphans_count_label">
                                        <property name="label" translatable="yes">No orphaned packages found</property>
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="orphans_size_label">
                                        <property name="label" translatable="yes">Total size: 0 MB</property>
                                        <property name="halign">end</property>
                                        <style>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkScrolledWindow">
                                    <property name="min-content-height">260</property>
                                    <property name="vexpand">true</property>
                                    <property name="hscrollbar-policy">automatic</property>
                                    <property name="vscrollbar-policy">automatic</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <property name="margin-bottom">12</property>
                                    <property name="child">
                                      <object class="GtkListBox" id="orphans_listbox">
                                        <property name="selection-mode">multiple</property>
                                        <style>
                                          <class name="boxed-list"/>
                                        </style>
                                        <signal name="row-activated" handler="on_orphan_row_activated"/>
                                        <signal name="selected-rows-changed" handler="on_orphan_selection_changed"/>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">end</property>

                            <child>
                              <object class="GtkButton" id="clean_all_orphans_button">
                                <property name="label" translatable="yes">Remove All Orphans</property>
                                <property name="icon-name">user-trash-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Remove all orphaned packages (paru -Qtdq | paru -Rns -)</property>
                                <style>
                                  <class name="destructive-action"/>
                                </style>
                                <signal name="clicked" handler="on_clean_all_orphans_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="remove_selected_orphans_button">
                                <property name="label" translatable="yes">Remove Selected</property>
                                <property name="icon-name">edit-delete-symbolic</property>
                                <property name="sensitive">false</property>
                                <property name="tooltip-text" translatable="yes">Remove selected orphaned packages</property>
                                <style>
                                  <class name="destructive-action"/>
                                </style>
                                <signal name="clicked" handler="on_remove_selected_orphans_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">explicit</property>
                    <property name="title" translatable="yes">Explicitly Installed</property>
                    <property name="icon-name">starred-symbolic</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Explicitly Installed Packages</property>
                            <property name="description" translatable="yes">Packages you intentionally installed</property>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">What Are Explicit Packages?</property>
                                <property name="subtitle" translatable="yes">Packages you directly installed with pacman/paru, not as dependencies</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">dialog-information-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Mark as Dependency</property>
                                <property name="subtitle" translatable="yes">Change installation reason from explicit to dependency</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">emblem-shared-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">start</property>

                            <child>
                              <object class="GtkButton" id="refresh_explicit_button">
                                <property name="label" translatable="yes">Refresh List</property>
                                <property name="icon-name">view-refresh-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Scan system for explicitly installed packages (paru -Qe)</property>
                                <signal name="clicked" handler="on_refresh_explicit_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="select_all_explicit_button">
                                <property name="label" translatable="yes">Select All</property>
                                <property name="icon-name">edit-select-all-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Select all explicit packages for bulk operation</property>
                                <signal name="clicked" handler="on_select_all_explicit_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="create_explicit_list_button">
                                <property name="label" translatable="yes">Export List</property>
                                <property name="icon-name">document-save-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Export explicit package list to file</property>
                                <signal name="clicked" handler="on_create_explicit_list_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="css-classes">card</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <property name="margin-top">12</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <child>
                                      <object class="GtkLabel" id="explicit_count_label">
                                        <property name="label" translatable="yes">Loading explicit packages...</property>
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="explicit_size_label">
                                        <property name="label" translatable="yes">Total size: calculating...</property>
                                        <property name="halign">end</property>
                                        <style>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkScrolledWindow">
                                    <property name="min-content-height">260</property>
                                    <property name="vexpand">true</property>
                                    <property name="hscrollbar-policy">automatic</property>
                                    <property name="vscrollbar-policy">automatic</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <property name="margin-bottom">12</property>
                                    <property name="child">
                                      <object class="GtkListBox" id="explicit_listbox">
                                        <property name="selection-mode">multiple</property>
                                        <style>
                                          <class name="boxed-list"/>
                                        </style>
                                        <signal name="row-activated" handler="on_explicit_row_activated"/>
                                        <signal name="selected-rows-changed" handler="on_explicit_selection_changed"/>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">end</property>

                            <child>
                              <object class="GtkButton" id="mark_as_deps_button">
                                <property name="label" translatable="yes">Mark as Dependencies</property>
                                <property name="icon-name">emblem-shared-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Mark selected packages as dependencies (paru -D --asdeps)</property>
                                <property name="sensitive">false</property>
                                <signal name="clicked" handler="on_mark_as_deps_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">dependencies</property>
                    <property name="title" translatable="yes">Dependencies</property>
                    <property name="icon-name">folder-download-symbolic</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Dependency Packages</property>
                            <property name="description" translatable="yes">Packages installed automatically to satisfy dependencies</property>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">What Are Dependencies?</property>
                                <property name="subtitle" translatable="yes">Packages automatically installed to support other packages</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">dialog-information-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Mark as Explicit</property>
                                <property name="subtitle" translatable="yes">Change installation reason from dependency to explicit</property>
                                <child type="prefix">
                                  <object class="GtkImage">
                                    <property name="icon-name">starred-symbolic</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">start</property>

                            <child>
                              <object class="GtkButton" id="refresh_deps_button">
                                <property name="label" translatable="yes">Refresh List</property>
                                <property name="icon-name">view-refresh-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Scan system for dependency packages (paru -Qd)</property>
                                <signal name="clicked" handler="on_refresh_deps_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="select_all_deps_button">
                                <property name="label" translatable="yes">Select All</property>
                                <property name="icon-name">edit-select-all-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Select all dependency packages for bulk operation</property>
                                <signal name="clicked" handler="on_select_all_deps_clicked"/>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="create_deps_list_button">
                                <property name="label" translatable="yes">Export List</property>
                                <property name="icon-name">document-save-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Export dependency package list to file</property>
                                <signal name="clicked" handler="on_create_deps_list_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="css-classes">card</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <property name="margin-top">12</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <child>
                                      <object class="GtkLabel" id="deps_count_label">
                                        <property name="label" translatable="yes">Loading dependency packages...</property>
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="deps_size_label">
                                        <property name="label" translatable="yes">Total size: calculating...</property>
                                        <property name="halign">end</property>
                                        <style>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkScrolledWindow">
                                    <property name="min-content-height">260</property>
                                    <property name="vexpand">true</property>
                                    <property name="hscrollbar-policy">automatic</property>
                                    <property name="vscrollbar-policy">automatic</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <property name="margin-bottom">12</property>
                                    <property name="child">
                                      <object class="GtkListBox" id="deps_listbox">
                                        <property name="selection-mode">multiple</property>
                                        <style>
                                          <class name="boxed-list"/>
                                        </style>
                                        <signal name="row-activated" handler="on_deps_row_activated"/>
                                        <signal name="selected-rows-changed" handler="on_deps_selection_changed"/>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">12</property>
                            <property name="halign">end</property>

                            <child>
                              <object class="GtkButton" id="mark_as_explicit_button">
                                <property name="label" translatable="yes">Mark as Explicit</property>
                                <property name="icon-name">starred-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Mark selected packages as explicitly installed (paru -D --asexplicit)</property>
                                <property name="sensitive">false</property>
                                <signal name="clicked" handler="on_mark_as_explicit_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>

        <child type="bottom">
          <object class="AdwHeaderBar">
            <property name="show-title">false</property>
            <child type="start">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkButton" id="system_tools_button">
                    <property name="label" translatable="yes">System Tools</property>
                    <property name="tooltip-text" translatable="yes">Return to System Tools</property>
                    <signal name="clicked" handler="on_system_tools_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="cancel_button">
                    <property name="label" translatable="yes">Close</property>
                    <property name="tooltip-text" translatable="yes">Close dialog</property>
                    <signal name="clicked" handler="on_cancel_clicked"/>
                  </object>
                </child>
              </object>
            </child>
            <child type="end">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>

                <child>
                  <object class="GtkLabel" id="status_label">
                    <property name="label" translatable="yes">Ready</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="execute_button">
                    <property name="label" translatable="yes">Execute Operation</property>
                    <property name="sensitive">false</property>
                    <property name="tooltip-text" translatable="yes">Execute the selected package management operation</property>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                    <signal name="clicked" handler="on_execute_clicked"/>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

