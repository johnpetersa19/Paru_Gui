<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.5"/>

  <object class="AdwDialog" id="SystemUpgradeDialog">
    <property name="title" translatable="yes">System Upgrade</property>
    <property name="content-width">900</property>
    <property name="content-height">750</property>
    <property name="can-close">true</property>

    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start">
              <object class="GtkBox" id="navigation_header">
                <property name="orientation">horizontal</property>
                <property name="spacing">8</property>
                <property name="valign">center</property>
                <child>
                  <object class="GtkButton" id="back_to_system_button">
                    <property name="icon-name">go-previous-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Back to System Menu</property>
                    <signal name="clicked" handler="on_back_to_system_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_label">
                    <property name="label" translatable="yes">Main › System › System Upgrade</property>
                    <property name="ellipsize">end</property>
                    <style>
                      <class name="caption"/>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
            <property name="title-widget">
              <object class="AdwWindowTitle">
                <property name="title" translatable="yes">System Upgrade</property>
                <property name="subtitle" translatable="yes">Comprehensive system update with backup and analysis</property>
              </object>
            </property>
            <child type="end">
              <object class="GtkBox" id="header_actions">
                <property name="spacing">4</property>
                <child>
                  <object class="GtkButton" id="create_backup_button">
                    <property name="icon-name">drive-harddisk-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Create System Backup Before Upgrade</property>
                    <signal name="clicked" handler="on_create_backup_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="help_button">
                    <property name="icon-name">help-contents-symbolic</property>
                    <property name="tooltip-text" translatable="yes">System Upgrade Help</property>
                    <signal name="clicked" handler="on_help_clicked"/>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <property name="content">
          <object class="GtkScrolledWindow">
            <property name="hscrollbar-policy">never</property>
            <property name="vscrollbar-policy">automatic</property>
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">800</property>
                <property name="tightening-threshold">600</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">24</property>
                    <property name="margin-top">24</property>
                    <property name="margin-bottom">24</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>

                    <child>
                      <object class="GtkRevealer" id="backup_status_revealer">
                        <property name="reveal-child">false</property>
                        <property name="transition-type">slide-down</property>
                        <child>
                          <object class="AdwBanner" id="backup_status_banner">
                            <property name="title" translatable="yes">Backup Status</property>
                            <property name="button-label" translatable="yes">View Details</property>
                            <signal name="button-clicked" handler="on_backup_details_clicked"/>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Pre-Upgrade Analysis</property>
                        <property name="description" translatable="yes">Analyze system status before performing upgrade</property>

                        <child>
                          <object class="AdwActionRow" id="system_health_row">
                            <property name="title" translatable="yes">System Health Check</property>
                            <property name="subtitle" translatable="yes">Verify system integrity before upgrade</property>
                            <child type="prefix">
                              <object class="GtkImage" id="health_status_icon">
                                <property name="icon-name">dialog-question-symbolic</property>
                                <property name="pixel-size">16</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                            <child type="suffix">
                              <object class="GtkBox" id="health_actions">
                                <property name="spacing">8</property>
                                <child>
                                  <object class="GtkLabel" id="health_status_label">
                                    <property name="label" translatable="yes">Not Checked</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="run_analysis_button">
                                    <property name="label" translatable="yes">Run Analysis</property>
                                    <property name="tooltip-text" translatable="yes">Perform comprehensive pre-upgrade analysis</property>
                                    <signal name="clicked" handler="on_run_analysis_clicked"/>
                                    <style>
                                      <class name="suggested-action"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow" id="disk_space_row">
                            <property name="title" translatable="yes">Available Disk Space</property>
                            <property name="subtitle" translatable="yes">Ensure sufficient space for upgrade</property>
                            <child type="prefix">
                              <object class="GtkImage" id="disk_status_icon">
                                <property name="icon-name">drive-harddisk-symbolic</property>
                                <property name="pixel-size">16</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                            <child type="suffix">
                              <object class="GtkLabel" id="disk_space_label">
                                <property name="label" translatable="yes">Checking...</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow" id="update_size_row">
                            <property name="title" translatable="yes">Estimated Download Size</property>
                            <property name="subtitle" translatable="yes">Total size of packages to be updated</property>
                            <child type="prefix">
                              <object class="GtkImage" id="download_status_icon">
                                <property name="icon-name">folder-download-symbolic</property>
                                <property name="pixel-size">16</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                            <child type="suffix">
                              <object class="GtkLabel" id="download_size_label">
                                <property name="label" translatable="yes">Calculating...</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Backup Integration</property>
                        <property name="description" translatable="yes">Create system backup before performing upgrade</property>

                        <child>
                          <object class="AdwSwitchRow" id="auto_backup_switch">
                            <property name="title" translatable="yes">Automatic Backup</property>
                            <property name="subtitle" translatable="yes">Create system backup automatically before upgrade</property>
                            <property name="active">true</property>
                            <signal name="notify::active" handler="on_backup_option_changed"/>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow" id="backup_location_row">
                            <property name="title" translatable="yes">Backup Location</property>
                            <property name="subtitle" translatable="yes">Choose backup destination</property>
                            <child type="suffix">
                              <object class="GtkBox" id="backup_location_actions">
                                <property name="spacing">8</property>
                                <child>
                                  <object class="GtkLabel" id="backup_location_label">
                                    <property name="label" translatable="yes">Default Location</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="choose_backup_location_button">
                                    <property name="label" translatable="yes">Choose</property>
                                    <property name="tooltip-text" translatable="yes">Select backup destination folder</property>
                                    <signal name="clicked" handler="on_choose_backup_location_clicked"/>
                                    <style>
                                      <class name="flat"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow" id="manual_backup_row">
                            <property name="title" translatable="yes">Create Backup Now</property>
                            <property name="subtitle" translatable="yes">Manually create system backup before upgrade</property>
                            <child type="suffix">
                              <object class="GtkButton" id="manual_backup_button">
                                <property name="label" translatable="yes">Create Backup</property>
                                <property name="tooltip-text" translatable="yes">Create system backup manually</property>
                                <signal name="clicked" handler="on_create_backup_clicked"/>
                                <style>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Upgrade Configuration</property>
                        <property name="description" translatable="yes">Configure system upgrade parameters</property>

                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Complete System Upgrade</property>
                            <property name="subtitle" translatable="yes">Update all packages including AUR packages (paru -Syu)</property>
                            <property name="activatable-widget">update_complete_radio</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="update_complete_radio">
                                <property name="active">true</property>
                                <signal name="toggled" handler="on_update_type_changed"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Repository Packages Only</property>
                            <property name="subtitle" translatable="yes">Update only official repository packages (paru -Su --repo)</property>
                            <property name="activatable-widget">update_repos_radio</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="update_repos_radio">
                                <property name="group">update_complete_radio</property>
                                <signal name="toggled" handler="on_update_type_changed"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">AUR Packages Only</property>
                            <property name="subtitle" translatable="yes">Update only AUR packages (paru -Su --aur)</property>
                            <property name="activatable-widget">update_aur_radio</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="update_aur_radio">
                                <property name="group">update_complete_radio</property>
                                <signal name="toggled" handler="on_update_type_changed"/>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Advanced Options</property>
                        <property name="description" translatable="yes">Additional configuration for the upgrade process</property>

                        <child>
                          <object class="AdwSwitchRow" id="force_db_switch">
                            <property name="title" translatable="yes">Force Database Refresh</property>
                            <property name="subtitle" translatable="yes">Force refresh of package databases (--refresh)</property>
                            <property name="active">true</property>
                            <signal name="notify::active" handler="on_option_changed"/>
                          </object>
                        </child>

                        <child>
                          <object class="AdwSwitchRow" id="devel_switch">
                            <property name="title" translatable="yes">Include Development Packages</property>
                            <property name="subtitle" translatable="yes">Update VCS packages: *-git, *-svn, *-hg (--devel)</property>
                            <signal name="notify::active" handler="on_option_changed"/>
                          </object>
                        </child>

                        <child>
                          <object class="AdwSwitchRow" id="noconfirm_switch">
                            <property name="title" translatable="yes">Automatic Mode</property>
                            <property name="subtitle" translatable="yes">Skip interactive prompts during upgrade (--noconfirm)</property>
                            <signal name="notify::active" handler="on_option_changed"/>
                          </object>
                        </child>

                        <child>
                          <object class="AdwSwitchRow" id="needed_switch">
                            <property name="title" translatable="yes">Skip Up-to-date Packages</property>
                            <property name="subtitle" translatable="yes">Do not reinstall up-to-date packages (--needed)</property>
                            <property name="active">true</property>
                            <signal name="notify::active" handler="on_option_changed"/>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Package Exclusions</property>
                        <property name="description" translatable="yes">Specify packages to ignore during upgrade</property>

                        <child>
                          <object class="AdwEntryRow" id="ignore_packages_entry">
                            <property name="title" translatable="yes">Ignored Package List</property>
                            <property name="text"></property>
                            <signal name="changed" handler="on_ignore_packages_changed"/>
                            <child type="suffix">
                              <object class="GtkButton" id="ignore_help_button">
                                <property name="icon-name">help-about-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Separate multiple packages with commas</property>
                                <property name="valign">center</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="circular"/>
                                </style>
                                <signal name="clicked" handler="on_ignore_help_clicked"/>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="ignore_example_label">
                            <property name="label" translatable="yes">Example: linux,nvidia,discord,firefox</property>
                            <property name="halign">start</property>
                            <property name="margin-start">16</property>
                            <style>
                              <class name="dim-label"/>
                              <class name="caption"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Command Preview</property>
                        <property name="description" translatable="yes">Review the command that will be executed</property>

                        <child>
                          <object class="GtkFrame">
                            <style>
                              <class name="card"/>
                            </style>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">16</property>
                                <property name="margin-top">20</property>
                                <property name="margin-bottom">20</property>
                                <property name="margin-start">20</property>
                                <property name="margin-end">20</property>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkImage" id="command_status_icon">
                                        <property name="icon-name">emblem-ok-symbolic</property>
                                        <property name="icon-size">large</property>
                                        <style>
                                          <class name="success"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">4</property>
                                        <property name="hexpand">true</property>
                                        <child>
                                          <object class="GtkLabel" id="command_status_label">
                                            <property name="label" translatable="yes">Command is ready for execution</property>
                                            <property name="halign">start</property>
                                            <style>
                                              <class name="heading"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="command_description_label">
                                            <property name="label" translatable="yes">This will perform a complete system upgrade</property>
                                            <property name="halign">start</property>
                                            <property name="wrap">true</property>
                                            <style>
                                              <class name="caption"/>
                                              <class name="dim-label"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkFrame">
                                    <style>
                                      <class name="view"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel" id="command_preview_label">
                                        <property name="label" translatable="yes">paru -Syu</property>
                                        <property name="halign">start</property>
                                        <property name="selectable">true</property>
                                        <property name="wrap">true</property>
                                        <property name="margin-top">12</property>
                                        <property name="margin-bottom">12</property>
                                        <property name="margin-start">16</property>
                                        <property name="margin-end">16</property>
                                        <style>
                                          <class name="monospace"/>
                                          <class name="title-3"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <child>
                                      <object class="GtkButton" id="copy_command_button">
                                        <property name="label" translatable="yes">Copy Command</property>
                                        <property name="tooltip-text" translatable="yes">Copy command to clipboard</property>
                                        <style>
                                          <class name="pill"/>
                                        </style>
                                        <child>
                                          <object class="GtkBox">
                                            <property name="spacing">6</property>
                                            <child>
                                              <object class="GtkImage">
                                                <property name="icon-name">edit-copy-symbolic</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="label" translatable="yes">Copy</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <signal name="clicked" handler="on_copy_command_clicked"/>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="test_command_button">
                                        <property name="label" translatable="yes">Test Command</property>
                                        <property name="tooltip-text" translatable="yes">Test command execution without making changes</property>
                                        <style>
                                          <class name="pill"/>
                                        </style>
                                        <signal name="clicked" handler="on_test_command_clicked"/>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Post-Upgrade Verification</property>
                        <property name="description" translatable="yes">Automatic verification after upgrade completion</property>

                        <child>
                          <object class="AdwSwitchRow" id="post_check_switch">
                            <property name="title" translatable="yes">Enable Post-Upgrade Check</property>
                            <property name="subtitle" translatable="yes">Verify system integrity after upgrade</property>
                            <property name="active">true</property>
                            <signal name="notify::active" handler="on_post_check_changed"/>
                          </object>
                        </child>

                        <child>
                          <object class="AdwSwitchRow" id="reboot_reminder_switch">
                            <property name="title" translatable="yes">Reboot Reminder</property>
                            <property name="subtitle" translatable="yes">Show reminder to reboot after critical updates</property>
                            <property name="active">true</property>
                            <signal name="notify::active" handler="on_reboot_reminder_changed"/>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>

        <child type="bottom">
          <object class="AdwHeaderBar">
            <property name="show-title">false</property>
            <child type="start">
              <object class="GtkButton" id="system_menu_button">
                <property name="label" translatable="yes">Back to System Menu</property>
                <property name="tooltip-text" translatable="yes">Return to main system menu</property>
                <signal name="clicked" handler="on_back_to_system_clicked"/>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="cancel_button">
                <property name="label" translatable="yes">Cancel</property>
                <signal name="clicked" handler="on_cancel_clicked"/>
              </object>
            </child>
            <child type="end">
              <object class="GtkBox" id="execute_actions">
                <property name="spacing">8</property>
                <child>
                  <object class="GtkButton" id="dry_run_button">
                    <property name="label" translatable="yes">Dry Run</property>
                    <property name="tooltip-text" translatable="yes">Preview upgrade without making changes</property>
                    <signal name="clicked" handler="on_dry_run_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="execute_button">
                    <property name="label" translatable="yes">Execute Upgrade</property>
                    <property name="tooltip-text" translatable="yes">Start system upgrade process</property>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                    <signal name="clicked" handler="on_execute_clicked"/>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <accessibility>
      <property name="label" translatable="yes">System Upgrade Dialog</property>
      <property name="description" translatable="yes">Comprehensive system upgrade tool with backup and analysis features</property>
    </accessibility>
  </object>
</interface>
