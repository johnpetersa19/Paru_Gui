<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.10"/>
  <requires lib="adw" version="1.4"/>

  <object class="AdwDialog" id="package_build_dialog">
    <property name="content-width">900</property>
    <property name="content-height">700</property>
    <property name="title" translatable="yes">Build Package</property>
    <property name="follows-content-size">true</property>

    <child>
      <object class="AdwToolbarView" id="dialog_toolbar_view">
        <child type="top">
          <object class="AdwHeaderBar" id="dialog_header_bar">
            <property name="centering-policy">strict</property>
            <property name="show-title">true</property>
            <child type="start">
              <object class="GtkBox" id="navigation_start_box">
                <property name="spacing">6</property>
                <child>
                  <object class="GtkButton" id="dialog_close_button">
                    <property name="icon-name">window-close-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Close build dialog</property>
                    <accessibility>
                      <property name="label" translatable="yes">Close dialog</property>
                    </accessibility>
                    <style>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="back_to_file_button">
                    <property name="label" translatable="yes">Back to File</property>
                    <property name="tooltip-text" translatable="yes">Return to PKGBUILD file view</property>
                    <accessibility>
                      <property name="label" translatable="yes">Return to PKGBUILD file view</property>
                    </accessibility>
                    <style>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton" id="build_options_menu">
                <property name="icon-name">preferences-system-symbolic</property>
                <property name="tooltip-text" translatable="yes">Build options and advanced settings</property>
                <property name="menu-model">build_options_menu_model</property>
                <accessibility>
                  <property name="label" translatable="yes">Build options menu</property>
                </accessibility>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="main_content_box">
            <property name="orientation">vertical</property>

            <child>
              <object class="GtkBox" id="breadcrumb_navigation">
                <property name="margin-bottom">0</property>
                <property name="margin-end">24</property>
                <property name="margin-start">24</property>
                <property name="margin-top">18</property>
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>

                <child>
                  <object class="GtkBox" id="breadcrumb_box">
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkButton" id="breadcrumb_content">
                        <property name="label" translatable="yes">Content</property>
                        <property name="tooltip-text" translatable="yes">Return to content management</property>
                        <style>
                          <class name="flat"/>
                          <class name="caption"/>
                        </style>
                        <accessibility>
                          <property name="label" translatable="yes">Navigate to content management</property>
                        </accessibility>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">›</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="breadcrumb_pkgbuild">
                        <property name="label" translatable="yes">PKGBUILD</property>
                        <property name="tooltip-text" translatable="yes">Return to PKGBUILD management</property>
                        <style>
                          <class name="flat"/>
                          <class name="caption"/>
                        </style>
                        <accessibility>
                          <property name="label" translatable="yes">Navigate to PKGBUILD management</property>
                        </accessibility>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">›</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="breadcrumb_filename">
                        <property name="label" translatable="yes">[File Name]</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">›</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Build</property>
                        <style>
                          <class name="caption"/>
                          <class name="accent"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkBox" id="review_warning_box">
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">dialog-warning-symbolic</property>
                        <property name="pixel-size">16</property>
                        <style>
                          <class name="warning"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Review PKGBUILD before building to ensure security and compatibility</property>
                        <style>
                          <class name="caption"/>
                          <class name="warning"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="review_pkgbuild_first_button">
                        <property name="label" translatable="yes">Review PKGBUILD First</property>
                        <property name="tooltip-text" translatable="yes">Open PKGBUILD for detailed review before building</property>
                        <style>
                          <class name="pill"/>
                          <class name="suggested-action"/>
                        </style>
                        <accessibility>
                          <property name="label" translatable="yes">Review PKGBUILD before building</property>
                        </accessibility>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkSeparator">
                <property name="margin-bottom">12</property>
                <property name="margin-end">24</property>
                <property name="margin-start">24</property>
                <property name="margin-top">12</property>
              </object>
            </child>

            <child>
              <object class="AdwViewStack" id="build_view_stack">
                <property name="vexpand">true</property>

                <child>
                  <object class="AdwViewStackPage" id="pkgbuild_page">
                    <property name="name">pkgbuild</property>
                    <property name="title" translatable="yes">PKGBUILD</property>
                    <property name="icon-name">text-x-generic-symbolic</property>
                    <property name="child">
                      <object class="GtkBox" id="pkgbuild_content_box">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>

                        <child>
                          <object class="GtkBox" id="pkgbuild_header_box">
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel" id="pkgbuild_info_label">
                                <property name="label" translatable="yes">Package Information</property>
                                <property name="halign">start</property>
                                <property name="hexpand">true</property>
                                <style>
                                  <class name="title-3"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="edit_pkgbuild_button">
                                <property name="label" translatable="yes">Edit</property>
                                <property name="tooltip-text" translatable="yes">Edit PKGBUILD file in external editor</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Edit PKGBUILD file</property>
                                </accessibility>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="reload_pkgbuild_button">
                                <property name="icon-name">view-refresh-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Reload PKGBUILD content from file</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Reload PKGBUILD</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkScrolledWindow" id="pkgbuild_scroll">
                            <property name="vexpand">true</property>
                            <property name="hscrollbar-policy">automatic</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <child>
                              <object class="GtkTextView" id="pkgbuild_textview">
                                <property name="editable">false</property>
                                <property name="monospace">true</property>
                                <property name="wrap-mode">none</property>
                                <property name="top-margin">12</property>
                                <property name="bottom-margin">12</property>
                                <property name="left-margin">12</property>
                                <property name="right-margin">12</property>
                                <accessibility>
                                  <property name="label" translatable="yes">PKGBUILD file content</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="pkgbuild_metadata_box">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <style>
                              <class name="card"/>
                            </style>
                            <child>
                              <object class="GtkBox" id="package_name_box">
                                <property name="spacing">12</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">6</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <child>
                                  <object class="GtkLabel" id="package_name_label">
                                    <property name="label" translatable="yes">Package:</property>
                                    <property name="halign">start</property>
                                    <property name="width-chars">12</property>
                                    <style>
                                      <class name="caption-heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="package_name_value">
                                    <property name="label">example-package</property>
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="selectable">true</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="package_version_box">
                                <property name="spacing">12</property>
                                <property name="margin-bottom">6</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <child>
                                  <object class="GtkLabel" id="package_version_label">
                                    <property name="label" translatable="yes">Version:</property>
                                    <property name="halign">start</property>
                                    <property name="width-chars">12</property>
                                    <style>
                                      <class name="caption-heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="package_version_value">
                                    <property name="label">1.0.0-1</property>
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="selectable">true</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="package_description_box">
                                <property name="spacing">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <child>
                                  <object class="GtkLabel" id="package_description_label">
                                    <property name="label" translatable="yes">Description:</property>
                                    <property name="halign">start</property>
                                    <property name="valign">start</property>
                                    <property name="width-chars">12</property>
                                    <style>
                                      <class name="caption-heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="package_description_value">
                                    <property name="label">Package description</property>
                                    <property name="halign">start</property>
                                    <property name="valign">start</property>
                                    <property name="hexpand">true</property>
                                    <property name="wrap">true</property>
                                    <property name="selectable">true</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStackPage" id="dependencies_page">
                    <property name="name">dependencies</property>
                    <property name="title" translatable="yes">Dependencies</property>
                    <property name="icon-name">package-x-generic-symbolic</property>
                    <property name="child">
                      <object class="GtkScrolledWindow" id="dependencies_scroll">
                        <property name="hscrollbar-policy">never</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <child>
                          <object class="GtkBox" id="dependencies_main_box">
                            <property name="orientation">vertical</property>
                            <property name="spacing">24</property>
                            <property name="margin-top">24</property>
                            <property name="margin-bottom">24</property>
                            <property name="margin-start">24</property>
                            <property name="margin-end">24</property>

                            <child>
                              <object class="GtkBox" id="depends_section">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="depends_title">
                                    <property name="label" translatable="yes">Runtime Dependencies</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="title-3"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="depends_listbox">
                                    <property name="selection-mode">none</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                    <accessibility>
                                      <property name="label" translatable="yes">Runtime dependencies list</property>
                                    </accessibility>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox" id="makedepends_section">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="makedepends_title">
                                    <property name="label" translatable="yes">Build Dependencies</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="title-3"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="makedepends_listbox">
                                    <property name="selection-mode">none</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                    <accessibility>
                                      <property name="label" translatable="yes">Build dependencies list</property>
                                    </accessibility>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox" id="checkdepends_section">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="checkdepends_title">
                                    <property name="label" translatable="yes">Check Dependencies</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="title-3"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="checkdepends_listbox">
                                    <property name="selection-mode">none</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                    <accessibility>
                                      <property name="label" translatable="yes">Check dependencies list</property>
                                    </accessibility>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox" id="optdepends_section">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="optdepends_title">
                                    <property name="label" translatable="yes">Optional Dependencies</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="title-3"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="optdepends_listbox">
                                    <property name="selection-mode">none</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                    <accessibility>
                                      <property name="label" translatable="yes">Optional dependencies list</property>
                                    </accessibility>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStackPage" id="sources_page">
                    <property name="name">sources</property>
                    <property name="title" translatable="yes">Sources</property>
                    <property name="icon-name">folder-download-symbolic</property>
                    <property name="child">
                      <object class="GtkBox" id="sources_main_box">
                        <property name="orientation">vertical</property>
                        <property name="spacing">24</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>

                        <child>
                          <object class="GtkBox" id="sources_header_box">
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkLabel" id="sources_title">
                                <property name="label" translatable="yes">Source Files</property>
                                <property name="halign">start</property>
                                <property name="hexpand">true</property>
                                <style>
                                  <class name="title-3"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="download_sources_button">
                                <property name="label" translatable="yes">Download Sources</property>
                                <property name="tooltip-text" translatable="yes">Download all source files required for building</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Download all source files</property>
                                </accessibility>
                                <style>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkScrolledWindow" id="sources_scroll">
                            <property name="vexpand">true</property>
                            <property name="hscrollbar-policy">never</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <child>
                              <object class="GtkListBox" id="sources_listbox">
                                <property name="selection-mode">none</property>
                                <style>
                                  <class name="boxed-list"/>
                                </style>
                                <accessibility>
                                  <property name="label" translatable="yes">Source files list</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="checksums_section">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <child>
                              <object class="GtkBox" id="checksums_header_box">
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="checksums_title">
                                    <property name="label" translatable="yes">Checksums</property>
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="title-4"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="verify_checksums_button">
                                    <property name="label" translatable="yes">Verify</property>
                                    <property name="tooltip-text" translatable="yes">Verify integrity of downloaded files</property>
                                    <accessibility>
                                      <property name="label" translatable="yes">Verify file checksums</property>
                                    </accessibility>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkListBox" id="checksums_listbox">
                                <property name="selection-mode">none</property>
                                <style>
                                  <class name="boxed-list"/>
                                </style>
                                <accessibility>
                                  <property name="label" translatable="yes">File checksums list</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStackPage" id="build_output_page">
                    <property name="name">build_output</property>
                    <property name="title" translatable="yes">Build Output</property>
                    <property name="icon-name">utilities-terminal-symbolic</property>
                    <property name="child">
                      <object class="GtkBox" id="build_output_main_box">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>

                        <child>
                          <object class="GtkBox" id="build_progress_box">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <property name="margin-top">12</property>
                            <property name="margin-bottom">6</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>
                            <child>
                              <object class="GtkBox" id="build_status_box">
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel" id="build_status_label">
                                    <property name="label" translatable="yes">Ready to build</property>
                                    <property name="halign">start</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="title-4"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkRevealer" id="build_progress_revealer">
                                    <property name="reveal-child">false</property>
                                    <property name="transition-type">slide-left</property>
                                    <child>
                                      <object class="GtkSpinner" id="build_spinner">
                                        <property name="spinning">true</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkProgressBar" id="build_progressbar">
                                <property name="show-text">true</property>
                                <property name="text" translatable="yes">0%</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Build progress indicator</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="realtime_log_header">
                            <property name="spacing">12</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Real-time Build Log</property>
                                <property name="halign">start</property>
                                <property name="hexpand">true</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="clear_log_button">
                                <property name="icon-name">edit-clear-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Clear build log</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Clear build log</property>
                                </accessibility>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="save_log_button">
                                <property name="icon-name">document-save-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Save build log to file</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Save build log</property>
                                </accessibility>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkScrolledWindow" id="build_output_scroll">
                            <property name="vexpand">true</property>
                            <property name="hscrollbar-policy">automatic</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>
                            <child>
                              <object class="GtkTextView" id="build_output_textview">
                                <property name="editable">false</property>
                                <property name="monospace">true</property>
                                <property name="wrap-mode">none</property>
                                <property name="top-margin">12</property>
                                <property name="bottom-margin">12</property>
                                <property name="left-margin">12</property>
                                <property name="right-margin">12</property>
                                <accessibility>
                                  <property name="label" translatable="yes">Real-time build output log</property>
                                </accessibility>
                                <style>
                                  <class name="card"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="AdwViewSwitcherBar" id="view_switcher_bar">
                <property name="stack">build_view_stack</property>
                <property name="reveal">true</property>
              </object>
            </child>
          </object>
        </child>

        <child type="bottom">
          <object class="AdwActionRow" id="action_bar">
            <property name="title" translatable="yes">Build Actions</property>
            <child type="suffix">
              <object class="GtkBox" id="action_buttons_box">
                <property name="spacing">6</property>
                <property name="margin-top">6</property>
                <property name="margin-bottom">6</property>
                <child>
                  <object class="GtkButton" id="clean_button">
                    <property name="label" translatable="yes">Clean</property>
                    <property name="tooltip-text" translatable="yes">Clean build directory and remove old files</property>
                    <accessibility>
                      <property name="label" translatable="yes">Clean build directory</property>
                    </accessibility>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="install_deps_button">
                    <property name="label" translatable="yes">Install Dependencies</property>
                    <property name="tooltip-text" translatable="yes">Install all build and runtime dependencies</property>
                    <accessibility>
                      <property name="label" translatable="yes">Install build dependencies</property>
                    </accessibility>
                    <style>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="build_button">
                    <property name="label" translatable="yes">Build Package</property>
                    <property name="tooltip-text" translatable="yes">Start building the package from source</property>
                    <accessibility>
                      <property name="label" translatable="yes">Start building the package</property>
                    </accessibility>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="install_button">
                    <property name="label" translatable="yes">Build &amp; Install</property>
                    <property name="tooltip-text" translatable="yes">Build package and install it to the system</property>
                    <accessibility>
                      <property name="label" translatable="yes">Build and install the package</property>
                    </accessibility>
                    <style>
                      <class name="destructive-action"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>

  <menu id="build_options_menu_model">
    <section>
      <item>
        <attribute name="action">build.skip-checksum</attribute>
        <attribute name="label" translatable="yes">Skip Checksum Verification</attribute>
      </item>
      <item>
        <attribute name="action">build.skip-pgp</attribute>
        <attribute name="label" translatable="yes">Skip PGP Verification</attribute>
      </item>
      <item>
        <attribute name="action">build.no-deps</attribute>
        <attribute name="label" translatable="yes">Skip Dependency Check</attribute>
      </item>
      <item>
        <attribute name="action">build.clean-build</attribute>
        <attribute name="label" translatable="yes">Clean Build</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="action">build.ccache</attribute>
        <attribute name="label" translatable="yes">Use ccache</attribute>
      </item>
      <item>
        <attribute name="action">build.distcc</attribute>
        <attribute name="label" translatable="yes">Use distcc</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="action">build.debug</attribute>
        <attribute name="label" translatable="yes">Build with Debug Symbols</attribute>
      </item>
      <item>
        <attribute name="action">build.strip</attribute>
        <attribute name="label" translatable="yes">Strip Debug Symbols</attribute>
      </item>
    </section>
  </menu>

  <object class="GtkListBoxRow" id="dependency_row_template">
    <child>
      <object class="AdwActionRow" id="dependency_action_row">
        <property name="activatable">false</property>
        <child type="prefix">
          <object class="GtkImage" id="dependency_status_icon">
            <property name="icon-name">object-select-symbolic</property>
            <style>
              <class name="success"/>
            </style>
          </object>
        </child>
        <child type="suffix">
          <object class="GtkButton" id="dependency_info_button">
            <property name="icon-name">help-about-symbolic</property>
            <property name="tooltip-text" translatable="yes">Show package information and details</property>
            <accessibility>
              <property name="label" translatable="yes">Package information</property>
            </accessibility>
            <style>
              <class name="flat"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkListBoxRow" id="source_row_template">
    <child>
      <object class="AdwActionRow" id="source_action_row">
        <property name="activatable">false</property>
        <child type="prefix">
          <object class="GtkImage" id="source_type_icon">
            <property name="icon-name">folder-download-symbolic</property>
          </object>
        </child>
        <child type="suffix">
          <object class="GtkBox" id="source_actions_box">
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="source_download_button">
                <property name="icon-name">folder-download-symbolic</property>
                <property name="tooltip-text" translatable="yes">Download this source file</property>
                <accessibility>
                  <property name="label" translatable="yes">Download source</property>
                </accessibility>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="source_verify_button">
                <property name="icon-name">security-high-symbolic</property>
                <property name="tooltip-text" translatable="yes">Verify source file integrity</property>
                <accessibility>
                  <property name="label" translatable="yes">Verify source</property>
                </accessibility>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkListBoxRow" id="checksum_row_template">
    <child>
      <object class="AdwActionRow" id="checksum_action_row">
        <property name="activatable">false</property>
        <child type="prefix">
          <object class="GtkImage" id="checksum_status_icon">
            <property name="icon-name">security-high-symbolic</property>
            <style>
              <class name="success"/>
            </style>
          </object>
        </child>
        <child type="suffix">
          <object class="GtkLabel" id="checksum_algorithm_label">
            <property name="label">SHA256</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>

</interface>
