<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.10"/>
  <requires lib="libadwaita" version="1.4"/>

  <object class="GtkDialog" id="package_install_dialog">
    <property name="default-height">700</property>
    <property name="default-width">900</property>
    <property name="destroy-with-parent">true</property>
    <property name="modal">true</property>
    <property name="resizable">true</property>
    <property name="title">Package Installation Wizard</property>
    <accessibility>
      <property name="label">Package installation wizard with step-by-step guidance</property>
    </accessibility>

    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="margin-bottom">0</property>
        <property name="margin-end">0</property>
        <property name="margin-start">0</property>
        <property name="margin-top">0</property>
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>

        <child>
          <object class="GtkHeaderBar" id="navigation_header">
            <property name="title-widget">
              <object class="GtkBox" id="breadcrumb_container">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkButton" id="breadcrumb_packages">
                    <property name="label">Packages</property>
                    <property name="tooltip-text">Return to package listing</property>
                    <style>
                      <class name="flat"/>
                      <class name="breadcrumb"/>
                    </style>
                    <signal name="clicked" handler="on_breadcrumb_packages_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_separator1">
                    <property name="label">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="breadcrumb_package">
                    <property name="label">[Package Name]</property>
                    <property name="tooltip-text">Return to package details</property>
                    <style>
                      <class name="flat"/>
                      <class name="breadcrumb"/>
                    </style>
                    <signal name="clicked" handler="on_breadcrumb_package_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_separator2">
                    <property name="label">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_current">
                    <property name="label">Install</property>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
              </object>
            </property>

            <child type="start">
              <object class="GtkButton" id="back_to_package_details_button">
                <property name="icon-name">go-previous-symbolic</property>
                <property name="tooltip-text">Back to Package Details - return to package information view</property>
                <style>
                  <class name="circular"/>
                  <class name="suggested-action"/>
                </style>
                <signal name="clicked" handler="on_back_to_package_details_clicked"/>
              </object>
            </child>

            <child type="end">
              <object class="GtkRevealer" id="progress_revealer">
                <property name="reveal-child">false</property>
                <property name="transition-type">slide-left</property>
                <property name="child">
                  <object class="GtkSpinner" id="operation_spinner">
                    <property name="spinning">false</property>
                    <property name="width-request">16</property>
                    <property name="height-request">16</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="wizard_progress_container">
            <property name="orientation">vertical</property>
            <property name="spacing">0</property>
            <property name="margin-start">24</property>
            <property name="margin-end">24</property>
            <property name="margin-top">16</property>
            <property name="margin-bottom">16</property>

            <child>
              <object class="GtkBox" id="step_indicator_container">
                <property name="orientation">horizontal</property>
                <property name="spacing">12</property>
                <property name="halign">center</property>

                <child>
                  <object class="GtkBox" id="step1_container">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="step1_number">
                        <property name="label">1</property>
                        <property name="width-request">24</property>
                        <property name="height-request">24</property>
                        <style>
                          <class name="circular"/>
                          <class name="suggested-action"/>
                          <class name="step-active"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="step1_label">
                        <property name="label">Configure</property>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkSeparator" id="step_separator1">
                    <property name="orientation">horizontal</property>
                    <property name="hexpand">true</property>
                    <style>
                      <class name="step-connector"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkBox" id="step2_container">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="step2_number">
                        <property name="label">2</property>
                        <property name="width-request">24</property>
                        <property name="height-request">24</property>
                        <style>
                          <class name="circular"/>
                          <class name="step-inactive"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="step2_label">
                        <property name="label">Install</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkSeparator" id="step_separator2">
                    <property name="orientation">horizontal</property>
                    <property name="hexpand">true</property>
                    <style>
                      <class name="step-connector"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkBox" id="step3_container">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="step3_number">
                        <property name="label">3</property>
                        <property name="width-request">24</property>
                        <property name="height-request">24</property>
                        <style>
                          <class name="circular"/>
                          <class name="step-inactive"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="step3_label">
                        <property name="label">Complete</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkStack" id="wizard_stack">
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <property name="transition-type">slide-left-right</property>
            <property name="transition-duration">300</property>

            <child>
              <object class="GtkStackPage">
                <property name="name">configure</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkBox" id="configure_step">
                        <property name="orientation">vertical</property>
                        <property name="spacing">24</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>

                        <child>
                          <object class="GtkBox" id="package_header">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">16</property>
                            <child>
                              <object class="GtkImage" id="package_icon">
                                <property name="halign">center</property>
                                <property name="icon-name">package-x-generic-symbolic</property>
                                <property name="pixel-size">64</property>
                                <property name="valign">center</property>
                                <style>
                                  <class name="accent"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="hexpand">true</property>
                                <property name="orientation">vertical</property>
                                <property name="spacing">8</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkLabel" id="package_name_label">
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <property name="label">Package Name</property>
                                        <property name="selectable">true</property>
                                        <style>
                                          <class name="title-1"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox" id="trust_indicators">
                                        <property name="spacing">6</property>
                                        <child>
                                          <object class="GtkImage" id="signature_indicator">
                                            <property name="icon-name">security-high-symbolic</property>
                                            <property name="tooltip-text">Package signature verified</property>
                                            <style>
                                              <class name="success"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkImage" id="trust_indicator">
                                            <property name="icon-name">emblem-ok-symbolic</property>
                                            <property name="tooltip-text">Trusted maintainer</property>
                                            <style>
                                              <class name="success"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="package_version_label">
                                    <property name="halign">start</property>
                                    <property name="label">Version: 1.0.0-1</property>
                                    <property name="selectable">true</property>
                                    <style>
                                      <class name="heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="package_description_label">
                                    <property name="halign">start</property>
                                    <property name="label">Package description will be displayed here</property>
                                    <property name="wrap">true</property>
                                    <style>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">18</property>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label">Installation Configuration</property>
                                    <style>
                                      <class name="heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkCheckButton" id="install_deps_check">
                                        <property name="active">true</property>
                                        <property name="label">Install missing dependencies automatically</property>
                                        <property name="tooltip-text">Automatically resolve and install required dependencies</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkCheckButton" id="verify_signature_check">
                                        <property name="active">true</property>
                                        <property name="label">Verify package signatures</property>
                                        <property name="tooltip-text">Verify cryptographic signatures for security</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkCheckButton" id="clean_build_check">
                                        <property name="active">true</property>
                                        <property name="label">Clean build directory after installation</property>
                                        <property name="tooltip-text">Remove temporary build files to save space</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkCheckButton" id="install_optional_check">
                                        <property name="label">Install selected optional dependencies</property>
                                        <property name="tooltip-text">Include optional dependencies marked below</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <property name="label">Required Dependencies</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="required_deps_count">
                                        <property name="label">0 packages</property>
                                        <style>
                                          <class name="caption"/>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="required_dependencies_list">
                                    <property name="selection-mode">none</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="halign">start</property>
                                        <property name="hexpand">true</property>
                                        <property name="label">Optional Dependencies</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="optional_deps_count">
                                        <property name="label">0 packages</property>
                                        <style>
                                          <class name="caption"/>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkListBox" id="optional_dependencies_list">
                                    <property name="selection-mode">multiple</property>
                                    <style>
                                      <class name="boxed-list"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="GtkStackPage">
                <property name="name">install</property>
                <property name="child">
                  <object class="GtkBox" id="install_step">
                    <property name="orientation">vertical</property>
                    <property name="spacing">24</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="margin-top">24</property>
                    <property name="margin-bottom">24</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <property name="halign">center</property>

                        <child>
                          <object class="GtkSpinner" id="install_spinner">
                            <property name="spinning">true</property>
                            <property name="width-request">48</property>
                            <property name="height-request">48</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="install_status_label">
                            <property name="label">Installing Package...</property>
                            <style>
                              <class name="title-2"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="install_progress_label">
                            <property name="label">Downloading sources and dependencies</property>
                            <style>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkProgressBar" id="install_progress_bar">
                        <property name="fraction">0.3</property>
                        <property name="show-text">true</property>
                        <property name="text">30%</property>
                        <property name="width-request">400</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkScrolledWindow" id="install_log_scroll">
                        <property name="height-request">200</property>
                        <property name="width-request">600</property>
                        <property name="hscrollbar-policy">automatic</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <child>
                          <object class="GtkTextView" id="install_log_view">
                            <property name="editable">false</property>
                            <property name="monospace">true</property>
                            <property name="wrap-mode">word</property>
                            <style>
                              <class name="card"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="GtkStackPage">
                <property name="name">complete</property>
                <property name="child">
                  <object class="GtkBox" id="complete_step">
                    <property name="orientation">vertical</property>
                    <property name="spacing">24</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="margin-top">24</property>
                    <property name="margin-bottom">24</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <property name="halign">center</property>

                        <child>
                          <object class="GtkImage" id="success_icon">
                            <property name="icon-name">emblem-ok-symbolic</property>
                            <property name="pixel-size">64</property>
                            <style>
                              <class name="success"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="completion_title">
                            <property name="label">Installation Complete!</property>
                            <style>
                              <class name="title-1"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="completion_message">
                            <property name="label">Package has been successfully installed and is ready to use.</property>
                            <property name="wrap">true</property>
                            <property name="justify">center</property>
                            <style>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="halign">center</property>

                        <child>
                          <object class="GtkButton" id="install_another_button">
                            <property name="label">Install Another Package</property>
                            <property name="tooltip-text">Return to package listing to install additional packages</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="pill"/>
                            </style>
                            <signal name="clicked" handler="on_install_another_clicked"/>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="view_installed_button">
                            <property name="label">View Installed Packages</property>
                            <property name="tooltip-text">Open installed packages manager</property>
                            <style>
                              <class name="flat"/>
                              <class name="pill"/>
                            </style>
                            <signal name="clicked" handler="on_view_installed_clicked"/>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child type="action">
      <object class="GtkButton" id="wizard_cancel_button">
        <property name="label">Cancel</property>
        <property name="tooltip-text">Cancel installation and return to package details</property>
        <accessibility>
          <property name="label">Cancel package installation</property>
        </accessibility>
        <signal name="clicked" handler="on_wizard_cancel_clicked"/>
      </object>
    </child>

    <child type="action">
      <object class="GtkButton" id="wizard_back_button">
        <property name="label">Back</property>
        <property name="tooltip-text">Return to previous step</property>
        <property name="visible">false</property>
        <signal name="clicked" handler="on_wizard_back_clicked"/>
      </object>
    </child>

    <child type="action">
      <object class="GtkButton" id="wizard_next_button">
        <property name="label">Start Installation</property>
        <property name="tooltip-text">Proceed to installation with selected configuration</property>
        <style>
          <class name="suggested-action"/>
        </style>
        <accessibility>
          <property name="label">Start package installation</property>
        </accessibility>
        <signal name="clicked" handler="on_wizard_next_clicked"/>
      </object>
    </child>

  </object>
</interface>
