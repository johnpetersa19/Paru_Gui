<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.4"/>
  <template class="EmptyDirectoryDialog" parent="AdwWindow">
    <property name="width-request">800</property>
    <property name="height-request">700</property>
    <property name="default-width">900</property>
    <property name="default-height">800</property>
    <property name="modal">True</property>
    <property name="resizable">True</property>
    <property name="content">
      <object class="GtkBox" id="main_container">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwHeaderBar" id="header_bar">
            <property name="show-end-title-buttons">True</property>
            <property name="title-widget">
              <object class="AdwWindowTitle" id="window_title">
                <property name="title">Empty Directory</property>
                <property name="subtitle">Set Up Your Project Workspace</property>
              </object>
            </property>
            <child type="start">
              <object class="GtkButton" id="back_button">
                <property name="icon-name">go-previous-symbolic</property>
                <property name="tooltip-text">Return to Directory Browser</property>
                <signal name="clicked" handler="on_back_clicked"/>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton" id="menu_button">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="tooltip-text">Additional Options</property>
                <property name="menu-model">directory_menu</property>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="breadcrumb_container">
            <property name="spacing">8</property>
            <property name="margin-start">16</property>
            <property name="margin-end">16</property>
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
            <style>
              <class name="navigation-breadcrumbs"/>
            </style>
            <child>
              <object class="GtkButton" id="breadcrumb_main">
                <property name="label">Main</property>
                <property name="tooltip-text">Return to Main Menu</property>
                <signal name="clicked" handler="on_breadcrumb_main_clicked"/>
                <style>
                  <class name="flat"/>
                  <class name="breadcrumb-button"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label">›</property>
                <style>
                  <class name="breadcrumb-separator"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="breadcrumb_projects">
                <property name="label">Projects</property>
                <property name="tooltip-text">Return to Project List</property>
                <signal name="clicked" handler="on_breadcrumb_projects_clicked"/>
                <style>
                  <class name="flat"/>
                  <class name="breadcrumb-button"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label">›</property>
                <style>
                  <class name="breadcrumb-separator"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="breadcrumb_current">
                <property name="label">Empty Directory Setup</property>
                <style>
                  <class name="breadcrumb-current"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkRevealer" id="progress_revealer">
            <property name="reveal-child">False</property>
            <property name="transition-type">slide-down</property>
            <child>
              <object class="GtkBox" id="progress_container">
                <property name="orientation">vertical</property>
                <property name="spacing">8</property>
                <property name="margin-start">16</property>
                <property name="margin-end">16</property>
                <property name="margin-top">8</property>
                <property name="margin-bottom">8</property>
                <style>
                  <class name="progress-container"/>
                </style>
                <child>
                  <object class="GtkLabel" id="progress_label">
                    <property name="label">Setting up project workspace...</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkProgressBar" id="progress_bar">
                    <property name="hexpand">True</property>
                    <property name="show-text">True</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow" id="content_scroll">
            <property name="vexpand">True</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vscrollbar-policy">automatic</property>
            <child>
              <object class="GtkBox" id="content_container">
                <property name="orientation">vertical</property>
                <property name="spacing">24</property>
                <property name="margin-start">24</property>
                <property name="margin-end">24</property>
                <property name="margin-top">24</property>
                <property name="margin-bottom">24</property>
                <child>
                  <object class="GtkBox" id="header_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkImage" id="empty_folder_icon">
                        <property name="icon-name">folder-symbolic</property>
                        <property name="pixel-size">96</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="dim-label"/>
                          <class name="empty-state-icon"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="header_title">
                        <property name="label">Empty Directory Detected</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="title-1"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="header_subtitle">
                        <property name="label">This directory contains no PKGBUILD files or project content. Choose how you'd like to get started with your new project.</property>
                        <property name="wrap">True</property>
                        <property name="justify">center</property>
                        <property name="max-width-chars">60</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="dim-label"/>
                          <class name="body"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="quick_actions_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                    <child>
                      <object class="GtkLabel" id="quick_actions_header">
                        <property name="label">Quick Actions</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="title-3"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkFlowBox" id="quick_actions_flow">
                        <property name="max-children-per-line">2</property>
                        <property name="min-children-per-line">1</property>
                        <property name="selection-mode">none</property>
                        <property name="column-spacing">16</property>
                        <property name="row-spacing">16</property>
                        <property name="homogeneous">True</property>
                        <child>
                          <object class="GtkFrame" id="create_new_frame">
                            <property name="width-request">350</property>
                            <property name="height-request">120</property>
                            <style>
                              <class name="card"/>
                              <class name="action-card"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="create_new_button">
                                <property name="hexpand">True</property>
                                <property name="vexpand">True</property>
                                <property name="tooltip-text">Create a new PKGBUILD file from template</property>
                                <signal name="clicked" handler="on_create_new_clicked"/>
                                <style>
                                  <class name="flat"/>
                                  <class name="card-button"/>
                                </style>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">document-new-symbolic</property>
                                        <property name="pixel-size">32</property>
                                        <style>
                                          <class name="accent"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Create New PKGBUILD</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkFrame" id="import_template_frame">
                            <property name="width-request">350</property>
                            <property name="height-request">120</property>
                            <style>
                              <class name="card"/>
                              <class name="action-card"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="import_template_button">
                                <property name="hexpand">True</property>
                                <property name="vexpand">True</property>
                                <property name="tooltip-text">Import and customize from available templates</property>
                                <signal name="clicked" handler="on_import_template_clicked"/>
                                <style>
                                  <class name="flat"/>
                                  <class name="card-button"/>
                                </style>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">folder-templates-symbolic</property>
                                        <property name="pixel-size">32</property>
                                        <style>
                                          <class name="accent"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Import from Template</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkFrame" id="browse_files_frame">
                            <property name="width-request">350</property>
                            <property name="height-request">120</property>
                            <style>
                              <class name="card"/>
                              <class name="action-card"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="browse_files_button">
                                <property name="hexpand">True</property>
                                <property name="vexpand">True</property>
                                <property name="tooltip-text">Browse and import existing files or archives</property>
                                <signal name="clicked" handler="on_browse_files_clicked"/>
                                <style>
                                  <class name="flat"/>
                                  <class name="card-button"/>
                                </style>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">folder-open-symbolic</property>
                                        <property name="pixel-size">32</property>
                                        <style>
                                          <class name="accent"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Browse for Files</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkFrame" id="change_directory_frame">
                            <property name="width-request">350</property>
                            <property name="height-request">120</property>
                            <style>
                              <class name="card"/>
                              <class name="action-card"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="change_directory_button">
                                <property name="hexpand">True</property>
                                <property name="vexpand">True</property>
                                <property name="tooltip-text">Select a different project directory</property>
                                <signal name="clicked" handler="on_change_directory_clicked"/>
                                <style>
                                  <class name="flat"/>
                                  <class name="card-button"/>
                                </style>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">folder-move-symbolic</property>
                                        <property name="pixel-size">32</property>
                                        <style>
                                          <class name="accent"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Select Different Directory</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="content_separator">
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">8</property>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="detailed_actions_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">20</property>
                    <child>
                      <object class="GtkLabel" id="detailed_actions_header">
                        <property name="label">Detailed Setup Options</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="title-3"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="aur_download_card">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <style>
                          <class name="card"/>
                        </style>
                        <child>
                          <object class="GtkBox" id="aur_header">
                            <property name="spacing">16</property>
                            <property name="margin-start">20</property>
                            <property name="margin-end">20</property>
                            <property name="margin-top">20</property>
                            <property name="margin-bottom">12</property>
                            <child>
                              <object class="GtkImage" id="aur_icon">
                                <property name="icon-name">folder-download-symbolic</property>
                                <property name="pixel-size">48</property>
                                <property name="valign">start</property>
                                <style>
                                  <class name="accent"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="aur_info">
                                <property name="orientation">vertical</property>
                                <property name="spacing">4</property>
                                <property name="hexpand">True</property>
                                <child>
                                  <object class="GtkLabel" id="aur_title">
                                    <property name="label">Download from AUR</property>
                                    <property name="xalign">0</property>
                                    <style>
                                      <class name="title-4"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="aur_description">
                                    <property name="label">Search and download PKGBUILD files from the Arch User Repository to get started with existing packages.</property>
                                    <property name="wrap">True</property>
                                    <property name="xalign">0</property>
                                    <property name="max-width-chars">50</property>
                                    <style>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="aur_search_container">
                            <property name="spacing">12</property>
                            <property name="margin-start">20</property>
                            <property name="margin-end">20</property>
                            <property name="margin-bottom">20</property>
                            <child>
                              <object class="GtkEntry" id="aur_search_entry">
                                <property name="placeholder-text">Search AUR packages...</property>
                                <property name="hexpand">True</property>
                                <property name="tooltip-text">Enter package name to search in AUR</property>
                                <signal name="activate" handler="on_aur_search_activate"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="aur_search_button">
                                <property name="label">Search AUR</property>
                                <property name="tooltip-text">Search for packages in AUR</property>
                                <signal name="clicked" handler="on_aur_search_clicked"/>
                                <style>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="aur_browse_button">
                                <property name="label">Browse All</property>
                                <property name="tooltip-text">Browse all available AUR packages</property>
                                <signal name="clicked" handler="on_aur_browse_clicked"/>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="create_pkgbuild_card">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <style>
                          <class name="card"/>
                        </style>
                        <child>
                          <object class="GtkBox" id="create_header">
                            <property name="spacing">16</property>
                            <property name="margin-start">20</property>
                            <property name="margin-end">20</property>
                            <property name="margin-top">20</property>
                            <property name="margin-bottom">12</property>
                            <child>
                              <object class="GtkImage" id="create_icon">
                                <property name="icon-name">document-new-symbolic</property>
                                <property name="pixel-size">48</property>
                                <property name="valign">start</property>
                                <style>
                                  <class name="accent"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="create_info">
                                <property name="orientation">vertical</property>
                                <property name="spacing">4</property>
                                <property name="hexpand">True</property>
                                <child>
                                  <object class="GtkLabel" id="create_title">
                                    <property name="label">Create Sample PKGBUILD</property>
                                    <property name="xalign">0</property>
                                    <style>
                                      <class name="title-4"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="create_description">
                                    <property name="label">Generate a new PKGBUILD file from customizable templates with guided setup assistance.</property>
                                    <property name="wrap">True</property>
                                    <property name="xalign">0</property>
                                    <property name="max-width-chars">50</property>
                                    <style>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkGrid" id="create_form">
                            <property name="row-spacing">12</property>
                            <property name="column-spacing">16</property>
                            <property name="margin-start">20</property>
                            <property name="margin-end">20</property>
                            <property name="margin-bottom">20</property>
                            <child>
                              <object class="GtkLabel" id="package_name_label">
                                <property name="label">Package Name:</property>
                                <property name="xalign">0</property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="package_name_entry">
                                <property name="placeholder-text">my-awesome-package</property>
                                <property name="hexpand">True</property>
                                <property name="tooltip-text">Enter the name for your new package</property>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="template_label">
                                <property name="label">Template Type:</property>
                                <property name="xalign">0</property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">1</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkDropDown" id="template_dropdown">
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item>Basic Package</item>
                                      <item>Git Package (-git)</item>
                                      <item>Python Package</item>
                                      <item>Library Package</item>
                                      <item>Application Package</item>
                                      <item>Minimal Template</item>
                                    </items>
                                  </object>
                                </property>
                                <property name="selected">0</property>
                                <property name="hexpand">True</property>
                                <property name="tooltip-text">Choose the type of package template</property>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">1</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="create_actions">
                                <property name="spacing">12</property>
                                <property name="halign">end</property>
                                <property name="margin-top">8</property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">2</property>
                                  <property name="column-span">2</property>
                                </layout>
                                <child>
                                  <object class="GtkButton" id="create_preview_button">
                                    <property name="label">Preview Template</property>
                                    <property name="tooltip-text">Preview the template before creating</property>
                                    <signal name="clicked" handler="on_create_preview_clicked"/>
                                    <style>
                                      <class name="flat"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="create_pkgbuild_button">
                                    <property name="label">Create PKGBUILD</property>
                                    <property name="tooltip-text">Create the PKGBUILD file with selected template</property>
                                    <signal name="clicked" handler="on_create_pkgbuild_clicked"/>
                                    <style>
                                      <class name="suggested-action"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="recent_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <property name="margin-top">16</property>
                    <child>
                      <object class="GtkLabel" id="recent_header">
                        <property name="label">Recent Projects and Templates</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="title-4"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkFlowBox" id="recent_actions_flowbox">
                        <property name="max-children-per-line">4</property>
                        <property name="min-children-per-line">2</property>
                        <property name="selection-mode">none</property>
                        <property name="column-spacing">12</property>
                        <property name="row-spacing">12</property>
                        <property name="homogeneous">True</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkActionBar" id="action_bar">
            <property name="revealed">True</property>
            <child type="start">
              <object class="GtkButton" id="help_button">
                <property name="label">Getting Started Guide</property>
                <property name="tooltip-text">Open help documentation for new projects</property>
                <signal name="clicked" handler="on_help_clicked"/>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="close_button">
                <property name="label">Close</property>
                <property name="tooltip-text">Close this dialog and return</property>
                <signal name="clicked" handler="on_close_clicked"/>
                <style>
                  <class name="suggested-action"/>
                  <class name="pill"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
  <menu id="directory_menu">
    <section>
      <item>
        <attribute name="label">Open in File Manager</attribute>
        <attribute name="action">directory.open-external</attribute>
      </item>
      <item>
        <attribute name="label">Show Directory Properties</attribute>
        <attribute name="action">directory.properties</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Refresh Directory</attribute>
        <attribute name="action">directory.refresh</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Change Permissions</attribute>
        <attribute name="action">directory.permissions</attribute>
      </item>
    </section>
  </menu>
</interface>
