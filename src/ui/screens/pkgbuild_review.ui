<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.97.8 -->
<interface>
  <!-- interface-name pkgbuild_review.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="PkgbuildReviewDialog" parent="GtkDialog">
    <property name="default-height">650</property>
    <property name="default-width">900</property>
    <!-- REMOVIDO: <property name="title" ...> -->
    <property name="modal">true</property>
    <property name="resizable">true</property>
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="show-title-buttons">true</property>
        <child type="title">
          <object class="GtkBox" id="header_title_box">
            <property name="halign">center</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkImage" id="pkgbuild_icon">
                <property name="icon-name">text-x-generic</property>
                <property name="pixel-size">24</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="header_title">
                <property name="label" translatable="yes">PKGBUILD Security Review</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="trust_indicator">
                <property name="ellipsize">end</property>
                <property name="label" translatable="yes"/>
                <property name="margin-start">8</property>
                <property name="visible">true</property>
                <style>
                  <class name="success-color"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox" id="main_box">
        <property name="margin-bottom">12</property>
        <property name="margin-end">12</property>
        <property name="margin-start">12</property>
        <property name="margin-top">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkBox" id="package_info_box">
            <property name="margin-bottom">8</property>
            <property name="spacing">16</property>
            <child>
              <object class="GtkImage" id="package_icon">
                <property name="icon-name">text-x-generic</property>
                <property name="pixel-size">48</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="details_box">
                <property name="orientation">vertical</property>
                <property name="spacing">4</property>
                <child>
                  <object class="GtkBox" id="name_box">
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkLabel" id="package_name">
                        <property name="label" translatable="yes">firefox-git</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                          <attribute name="size" value="16000"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="package_trust_label">
                        <property name="ellipsize">end</property>
                        <property name="label" translatable="yes"/>
                        <style>
                          <class name="success-color"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="version_box">
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel" id="version_label">
                        <property name="label" translatable="yes">Version: 120.0.r12345-1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="source_label">
                        <property name="label" translatable="yes">Source: AUR</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="votes_label">
                        <property name="label" translatable="yes">Votes: 256</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="package_path">
                    <property name="label" translatable="yes">Path: /home/user/packages/firefox-git/PKGBUILD</property>
                    <style>
                      <class name="caption"/>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="steps_nav_box">
            <property name="margin-bottom">8</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkLabel" id="step_label">
                <property name="label" translatable="yes">Review Steps:</property>
                <style>
                  <class name="caption"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="step1_button">
                <property name="active">true</property>
                <property name="label" translatable="yes">1. Critical Changes</property>
                <property name="name">step1</property>
                <signal name="toggled" handler="on_step_toggled"/>
                <style>
                  <class name="flat"/>
                  <class name="step-button"/>
                  <class name="active-step"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="step2_button">
                <property name="active">True</property>
                <property name="label" translatable="yes">2. Risk Checklist</property>
                <property name="name">step2</property>
                <signal name="toggled" handler="on_step_toggled"/>
                <style>
                  <class name="flat"/>
                  <class name="step-button"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="step1_content">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <property name="visible">true</property>
            <child>
              <object class="GtkLabel" id="step1_description">
                <property name="label" translatable="yes">Review critical changes in the PKGBUILD that may affect security:</property>
                <property name="margin-bottom">8</property>
                <property name="xalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="critical_sections_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkBox" id="source_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="source_header">
                        <property name="label" translatable="yes">Source URLs</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="source_description">
                        <property name="label" translatable="yes">Review source URLs to ensure they're from trusted domains:</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow" id="source_diff_scroll">
                        <property name="hscrollbar-policy">automatic</property>
                        <property name="vexpand">true</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <child>
                          <object class="GtkTextView" id="source_diff_view">
                            <property name="bottom-margin">8</property>
                            <property name="cursor-visible">false</property>
                            <property name="editable">false</property>
                            <property name="left-margin">8</property>
                            <property name="monospace">true</property>
                            <property name="right-margin">8</property>
                            <property name="top-margin">8</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="prepare_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="prepare_header">
                        <property name="label" translatable="yes">Prepare Function</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="prepare_description">
                        <property name="label" translatable="yes">Review commands that run before building (may contain dangerous operations):</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow" id="prepare_diff_scroll">
                        <property name="hscrollbar-policy">automatic</property>
                        <property name="vexpand">true</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <child>
                          <object class="GtkTextView" id="prepare_diff_view">
                            <property name="bottom-margin">8</property>
                            <property name="cursor-visible">false</property>
                            <property name="editable">false</property>
                            <property name="left-margin">8</property>
                            <property name="monospace">true</property>
                            <property name="right-margin">8</property>
                            <property name="top-margin">8</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="package_section">
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel" id="package_header">
                        <property name="label" translatable="yes">Package Function</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="package_description">
                        <property name="label" translatable="yes">Review installation commands (may modify system files):</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow" id="package_diff_scroll">
                        <property name="hscrollbar-policy">automatic</property>
                        <property name="vexpand">true</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <child>
                          <object class="GtkTextView" id="package_diff_view">
                            <property name="bottom-margin">8</property>
                            <property name="cursor-visible">false</property>
                            <property name="editable">false</property>
                            <property name="left-margin">8</property>
                            <property name="monospace">true</property>
                            <property name="right-margin">8</property>
                            <property name="top-margin">8</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="step2_content">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <property name="visible">false</property>
            <child>
              <object class="GtkLabel" id="step2_description">
                <property name="label" translatable="yes">Check for potential security risks before proceeding:</property>
                <property name="margin-bottom">8</property>
                <property name="xalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="risk_checklist_box">
                <property name="orientation">vertical</property>
                <property name="spacing">8</property>
                <child>
                  <object class="GtkBox" id="risk_sudo_box">
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkCheckButton" id="risk_sudo_check">
                        <property name="active">True</property>
                        <property name="inconsistent">false</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_sudo_details">
                        <property name="orientation">vertical</property>
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkLabel" id="risk_sudo_title">
                            <property name="label" translatable="yes">Contains sudo commands</property>
                            <attributes>
                              <attribute name="weight" value="bold"/>
                            </attributes>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="risk_sudo_description">
                            <property name="label" translatable="yes">PKGBUILD contains sudo commands which could modify system files. This is dangerous unless it's an official package.</property>
                            <property name="wrap">true</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="caption"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="risk_unverified_sources_box">
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkCheckButton" id="risk_unverified_sources_check">
                        <property name="active">false</property>
                        <property name="inconsistent">true</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_unverified_sources_details">
                        <property name="orientation">vertical</property>
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkLabel" id="risk_unverified_sources_title">
                            <property name="label" translatable="yes">Unverified source URLs</property>
                            <attributes>
                              <attribute name="weight" value="bold"/>
                            </attributes>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="risk_unverified_sources_description">
                            <property name="label" translatable="yes">Source URLs are not from trusted domains or lack proper verification. Consider verifying the source authenticity.</property>
                            <property name="wrap">true</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="caption"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="risk_system_modification_box">
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkCheckButton" id="risk_system_modification_check">
                        <property name="active">true</property>
                        <property name="inconsistent">false</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_system_modification_details">
                        <property name="orientation">vertical</property>
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkLabel" id="risk_system_modification_title">
                            <property name="label" translatable="yes">Modifies system files</property>
                            <attributes>
                              <attribute name="weight" value="bold"/>
                            </attributes>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="risk_system_modification_description">
                            <property name="label" translatable="yes">PKGBUILD modifies system files outside standard package directories. This could cause system instability.</property>
                            <property name="wrap">true</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="caption"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="risk_patch_sources_box">
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkCheckButton" id="risk_patch_sources_check">
                        <property name="active">true</property>
                        <property name="inconsistent">false</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_patch_sources_details">
                        <property name="orientation">vertical</property>
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkLabel" id="risk_patch_sources_title">
                            <property name="label" translatable="yes">Uses external patch sources</property>
                            <attributes>
                              <attribute name="weight" value="bold"/>
                            </attributes>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="risk_patch_sources_description">
                            <property name="label" translatable="yes">PKGBUILD applies patches from external sources. Ensure patches are from trusted repositories.</property>
                            <property name="wrap">true</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="caption"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="risk_summary_box">
                    <property name="margin-top">8</property>
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkImage" id="risk_summary_icon">
                        <property name="icon-name">dialog-warning-symbolic</property>
                        <property name="pixel-size">24</property>
                        <style>
                          <class name="warning-color"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="risk_summary_text">
                        <property name="label" translatable="yes">This PKGBUILD has potential security risks. Proceed with caution.</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="risk_heatmap_box">
                <property name="margin-top">12</property>
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkLabel" id="heatmap_title">
                    <property name="label" translatable="yes">Risk Analysis Heatmap</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                    </attributes>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="heatmap_description">
                    <property name="label" translatable="yes">Highlighted sections indicate potential risk areas:</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="caption"/>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="heatmap_legend">
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkBox" id="risk_critical_legend">
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkFrame" id="critical_indicator">
                            <property name="height-request">16</property>
                            <property name="margin-bottom">2</property>
                            <property name="margin-end">2</property>
                            <property name="margin-start">2</property>
                            <property name="margin-top">2</property>
                            <property name="width-request">16</property>
                            <style>
                              <class name="risk-critical"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="critical_label">
                            <property name="label" translatable="yes">Critical Risk</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_high_legend">
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkFrame" id="high_indicator">
                            <property name="height-request">16</property>
                            <property name="margin-bottom">2</property>
                            <property name="margin-end">2</property>
                            <property name="margin-start">2</property>
                            <property name="margin-top">2</property>
                            <property name="width-request">16</property>
                            <style>
                              <class name="risk-high"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="high_label">
                            <property name="label" translatable="yes">High Risk</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_medium_legend">
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkFrame" id="medium_indicator">
                            <property name="height-request">16</property>
                            <property name="margin-bottom">2</property>
                            <property name="margin-end">2</property>
                            <property name="margin-start">2</property>
                            <property name="margin-top">2</property>
                            <property name="width-request">16</property>
                            <style>
                              <class name="risk-medium"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="medium_label">
                            <property name="label" translatable="yes">Medium Risk</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="risk_low_legend">
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkFrame" id="low_indicator">
                            <property name="height-request">16</property>
                            <property name="margin-bottom">2</property>
                            <property name="margin-end">2</property>
                            <property name="margin-start">2</property>
                            <property name="margin-top">2</property>
                            <property name="width-request">16</property>
                            <style>
                              <class name="risk-low"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="low_label">
                            <property name="label" translatable="yes">Low Risk</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow" id="heatmap_scroll">
                    <property name="height-request">150</property>
                    <property name="hscrollbar-policy">automatic</property>
                    <property name="vexpand">true</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <child>
                      <object class="GtkTextView" id="heatmap_view">
                        <property name="bottom-margin">8</property>
                        <property name="cursor-visible">false</property>
                        <property name="editable">false</property>
                        <property name="left-margin">8</property>
                        <property name="monospace">true</property>
                        <property name="right-margin">8</property>
                        <property name="top-margin">8</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child internal-child="action_area">
      <object class="GtkBox">
        <property name="margin-bottom">12</property>
        <property name="margin-end">12</property>
        <property name="margin-start">12</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkButton" id="cancel_button">
            <property name="label" translatable="yes">Cancel</property>
            <signal name="clicked" handler="on_cancel_clicked"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="previous_button">
            <property name="label" translatable="yes">Previous</property>
            <property name="visible">false</property>
            <signal name="clicked" handler="on_previous_clicked"/>
            <style>
              <class name="flat"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="next_button">
            <property name="label" translatable="yes">Next</property>
            <signal name="clicked" handler="on_next_clicked"/>
            <style>
              <class name="flat"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="build_button">
            <property name="label" translatable="yes">Build Package</property>
            <property name="visible">false</property>
            <signal name="clicked" handler="on_build_clicked"/>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
