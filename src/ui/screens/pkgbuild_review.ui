<?xml version='1.0' encoding='UTF-8'?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.10"/>
  <requires lib="libadwaita" version="1.4"/>

  <template class="PkgbuildReviewDialog" parent="AdwDialog">
    <property name="title" translatable="yes">PKGBUILD Security Review</property>
    <property name="content-width">600</property>
    <property name="content-height">700</property>
    <accessibility>
      <property name="label">PKGBUILD security analysis and review dialog</property>
    </accessibility>

    <child>

      <object class="GtkBox">
        <property name="orientation">vertical</property>

        <child>
          <object class="GtkScrolledWindow">
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">true</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">18</property>
                <property name="margin-top">12</property>
                <property name="margin-bottom">12</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>

                <child>
                  <object class="GtkBox" id="package_info_box">
                    <property name="spacing">16</property>
                    <child>
                      <object class="GtkImage" id="package_icon">
                        <property name="icon-name">text-x-generic-symbolic</property>
                        <property name="pixel-size">64</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="details_box">
                        <property name="orientation">vertical</property>
                        <property name="spacing">4</property>
                        <property name="hexpand">true</property>
                        <child>
                          <object class="GtkLabel" id="package_name">
                            <property name="label">package-name</property>
                            <property name="halign">start</property>
                            <attributes>
                              <attribute name="weight" value="bold"/>
                              <attribute name="scale" value="1.5"/>
                            </attributes>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="package_details">
                            <property name="label">Version: 1.0 | Votes: 100 | Source: AUR</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="AdwViewSwitcher" id="step_switcher">
                    <property name="stack">review_view_stack</property>
                    <property name="policy">wide</property>
                  </object>
                </child>

                <child>
                  <object class="AdwViewStack" id="review_view_stack">

                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">step1</property>
                        <property name="title" translatable="yes">Diff Review</property>
                        <property name="icon-name">edit-find-replace-symbolic</property>
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">18</property>
                            <property name="margin-top">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Review critical changes in the PKGBUILD that may affect security.</property>
                                <property name="halign">start</property>
                                <style><class name="dim-label"/></style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Source URLs</property>
                                    <property name="halign">start</property>
                                    <style><class name="heading"/></style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkFrame" id="source_diff_frame">
                                    <property name="child">
                                      <object class="GtkTextView" id="source_diff_view">
                                        <property name="editable">false</property>
                                        <property name="monospace">true</property>
                                        <property name="height-request">100</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">step2</property>
                        <property name="title" translatable="yes">Risk Checklist</property>
                        <property name="icon-name">security-high-symbolic</property>
                        <property name="child">
                          <object class="AdwPreferencesPage">
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Potential Security Risks</property>
                                <child>
                                  <object class="AdwSwitchRow" id="risk_sudo_row">
                                    <property name="title" translatable="yes">Contains `sudo` commands</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="AdwSwitchRow" id="risk_unverified_sources_row">
                                    <property name="title" translatable="yes">Unverified Source URLs</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Risk Analysis Heatmap</property>
                                <child>
                                  <object class="GtkFrame">
                                    <property name="child">
                                      <object class="GtkTextView" id="heatmap_view">
                                        <property name="editable">false</property>
                                        <property name="monospace">true</property>
                                        <property name="height-request">200</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">step3</property>
                        <property name="title" translatable="yes">Build Settings</property>
                        <property name="icon-name">applications-engineering-symbolic</property>
                        <property name="child">
                          <object class="AdwPreferencesPage">
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Build Environment</property>
                                <child>
                                  <object class="AdwExpanderRow" id="sandbox_expander_row">
                                    <property name="title" translatable="yes">Sandbox Settings</property>
                                    <property name="subtitle" translatable="yes">Isolate the build process.</property>
                                    <property name="show-enable-switch">true</property>
                                    <child type="row">
                                      <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Isolation Level</property>
                                        <child type="suffix">
                                          <object class="GtkDropDown" id="sandbox_level_combo">
                                            <property name="model">
                                              <object class="GtkStringList">
                                                <items>
                                                  <item translatable="yes">Strict</item>
                                                  <item translatable="yes">Medium</item>
                                                  <item translatable="yes">Minimal</item>
                                                </items>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>

              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkSeparator" />
        </child>

        <child>
          <object class="GtkBox" id="action_area">
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">6</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>

            <child>
              <object class="GtkButton" id="cancel_button">
                <property name="label" translatable="yes">_Cancel</property>
                <property name="use-underline">true</property>
                <signal name="clicked" handler="on_cancel_clicked"/>
                <accessibility>
                  <property name="label">Cancel security review and close dialog</property>
                </accessibility>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="previous_button">
                <property name="label" translatable="yes">_Previous</property>
                <property name="use-underline">true</property>
                <property name="visible">False</property>
                <signal name="clicked" handler="on_previous_clicked"/>
                <accessibility>
                  <property name="label">Go to previous review step</property>
                </accessibility>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="next_button">
                <property name="label" translatable="yes">_Next</property>
                <property name="use-underline">true</property>
                <signal name="clicked" handler="on_next_clicked"/>
                <accessibility>
                  <property name="label">Go to next review step</property>
                </accessibility>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="build_button">
                <property name="label" translatable="yes">_Build Package</property>
                <property name="use-underline">true</property>
                <property name="visible">False</property>
                <signal name="clicked" handler="on_build_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
                <accessibility>
                  <property name="label">Build package after security review completion</property>
                </accessibility>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>
  </template>
</interface>
