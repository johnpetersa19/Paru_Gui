<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.14"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="ContentView" parent="AdwBin">
    <style>
      <class name="view-root"/>
    </style>

    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar" id="content_header">
            <property name="title-widget">
              <object class="AdwWindowTitle">
                <property name="title" translatable="yes">Content Browser</property>
                <property name="subtitle" translatable="yes">Main &#8250; Content &#8250; Files</property>
              </object>
            </property>
            <child type="start">
          <object class="GtkBox">
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="up_button">
                <property name="icon-name">go-previous-symbolic</property>
                <property name="tooltip-text" translatable="yes">Go up one level</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="home_button">
                <property name="icon-name">go-home-symbolic</property>
                <property name="tooltip-text" translatable="yes">Go to home directory</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child type="end">
          <object class="GtkBox">
            <property name="spacing">6</property>
            <child>
              <object class="GtkToggleButton" id="search_toggle">
                <property name="icon-name">system-search-symbolic</property>
                <property name="tooltip-text" translatable="yes">Toggle search</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkMenuButton" id="view_options_button">
                <property name="icon-name">view-more-symbolic</property>
                <property name="tooltip-text" translatable="yes">View and sort options</property>
                <property name="popover">
                  <object class="GtkPopoverMenu">
                    <property name="menu-model">
                      <object class="GMenu">
                        <section>
                          <submenu>
                            <attribute name="label" translatable="yes">View Mode</attribute>
                            <section>
                              <item>
                                <attribute name="label" translatable="yes">Grid View</attribute>
                                <attribute name="action">content.view-mode</attribute>
                                <attribute name="target">grid</attribute>
                              </item>
                              <item>
                                <attribute name="label" translatable="yes">List View</attribute>
                                <attribute name="action">content.view-mode</attribute>
                                <attribute name="target">list</attribute>
                              </item>
                            </section>
                          </submenu>
                        </section>
                        <section>
                          <submenu>
                            <attribute name="label" translatable="yes">Sort By</attribute>
                            <section>
                              <item>
                                <attribute name="label" translatable="yes">Name</attribute>
                                <attribute name="action">content.sort-by</attribute>
                                <attribute name="target">name</attribute>
                              </item>
                              <item>
                                <attribute name="label" translatable="yes">Date Modified</attribute>
                                <attribute name="action">content.sort-by</attribute>
                                <attribute name="target">date</attribute>
                              </item>
                              <item>
                                <attribute name="label" translatable="yes">Size</attribute>
                                <attribute name="action">content.sort-by</attribute>
                                <attribute name="target">size</attribute>
                              </item>
                              <item>
                                <attribute name="label" translatable="yes">Type</attribute>
                                <attribute name="action">content.sort-by</attribute>
                                <attribute name="target">type</attribute>
                              </item>
                            </section>
                          </submenu>
                        </section>
                        <section>
                          <item>
                            <attribute name="label" translatable="yes">Add to Favorites</attribute>
                            <attribute name="action">content.add-favorite</attribute>
                          </item>
                          <item>
                            <attribute name="label" translatable="yes">Manage Favorites</attribute>
                            <attribute name="action">content.manage-favorites</attribute>
                          </item>
                        </section>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>

            <child>
              <object class="AdwPreferencesGroup" id="search_group">
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-top">6</property>
                <property name="margin-bottom">6</property>
                <child>
                  <object class="AdwEntryRow" id="search_entry_row">
                    <property name="title" translatable="yes">Search files...</property>
                    <property name="show-apply-button">false</property>
                    <property name="input-hints">no-spellcheck</property>
                    <child type="prefix">
                      <object class="GtkImage">
                        <property name="icon-name">system-search-symbolic</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                    <child type="suffix">
                      <object class="GtkButton" id="clear_file_search_button">
                        <property name="icon-name">edit-clear-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Clear search</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="flat"/>
                          <class name="circular"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

    <child>
      <object class="GtkBox" id="path_and_controls_bar">
        <property name="spacing">12</property>
        <style>
          <class name="view-section"/>
        </style>

        <child>
          <object class="GtkFrame">
            <property name="css-classes">quick-card</property>
            <property name="child">
              <object class="GtkBox">
                <property name="spacing">12</property>
                <property name="margin-top">8</property>
                <property name="margin-bottom">8</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>

                <child>
                  <object class="GtkImage">
                    <property name="icon-name">folder-symbolic</property>
                    <property name="pixel-size">16</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel" id="current_path_label">
                    <property name="ellipsize">middle</property>
                    <property name="halign">start</property>
                    <property name="hexpand">true</property>
                    <property name="label">/home/user</property>
                    <property name="max-width-chars">50</property>
                    <property name="wrap">false</property>
                    <property name="selectable">true</property>
                    <style>
                      <class name="monospace"/>
                    </style>
                    <property name="tooltip-text" translatable="yes">Current directory path - click to select</property>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="add_favorite_button">
                    <property name="icon-name">non-starred-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Add current path to favorites</property>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkMenuButton" id="favorites_button">
                    <property name="icon-name">starred-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Quick access to favorite paths</property>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                    </style>
                    <property name="popover">
                      <object class="GtkPopover">
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <property name="margin-top">12</property>
                            <property name="margin-bottom">12</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Favorite Paths</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkListBox" id="favorites_listbox">
                                <property name="selection-mode">none</property>
                                <style>
                                  <class name="boxed-list"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="filter_and_view_controls">
        <property name="spacing">12</property>
        <style>
          <class name="view-section"/>
        </style>

        <child>
          <object class="GtkFlowBox" id="filter_buttons">
            <property name="column-spacing">6</property>
            <property name="row-spacing">6</property>
            <property name="selection-mode">none</property>
            <child>
              <object class="GtkToggleButton" id="filter_pkgbuild">
                <property name="active">true</property>
                <property name="label" translatable="yes">PKGBUILD</property>
                <property name="name">PKGBUILD</property>
                <style>
                  <class name="filter-button"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Show PKGBUILD files</property>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="filter_packages">
                <property name="active">true</property>
                <property name="label" translatable="yes">Packages</property>
                <property name="name">PACKAGE</property>
                <style>
                  <class name="filter-button"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Show pre-compiled package files (.pkg.tar.zst)</property>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="filter_patches">
                <property name="active">true</property>
                <property name="label" translatable="yes">Patches</property>
                <property name="name">PATCH</property>
                <style>
                  <class name="filter-button"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Show patch files (.patch, .diff)</property>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="filter_advanced">
                <property name="active">true</property>
                <property name="label" translatable="yes">Advanced</property>
                <property name="name">ADVANCED</property>
                <style>
                  <class name="filter-button"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Show other compatible files and advanced options</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="hexpand">true</property>
            <property name="spacing">6</property>

            <child>
              <object class="GtkDropDown" id="sort_dropdown">
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Sort by Name</item>
                      <item translatable="yes">Sort by Date</item>
                      <item translatable="yes">Sort by Size</item>
                      <item translatable="yes">Sort by Type</item>
                    </items>
                  </object>
                </property>
                <property name="selected">0</property>
                <property name="tooltip-text" translatable="yes">Choose sorting method</property>
              </object>
            </child>

            <child>
              <object class="GtkToggleButton" id="sort_order_button">
                <property name="icon-name">view-sort-ascending-symbolic</property>
                <property name="tooltip-text" translatable="yes">Toggle sort order (ascending/descending)</property>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>

            <child>
              <object class="AdwViewSwitcher" id="view_switcher">
                <property name="stack">view_stack</property>
                <property name="policy">narrow</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="main_content_area">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <property name="vexpand">true</property>
        <style>
          <class name="view-section"/>
        </style>

        <child>
          <object class="AdwViewStack" id="view_stack">
            <property name="vexpand">true</property>

            <child>
              <object class="AdwViewStackPage">
                <property name="name">grid</property>
                <property name="title" translatable="yes">Grid View</property>
                <property name="child">
                  <object class="GtkScrolledWindow" id="grid_scrolled_content">
                    <property name="hscrollbar-policy">automatic</property>
                    <property name="vexpand">true</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <child>
                      <object class="GtkFlowBox" id="content_cards">
                        <property name="accept-unpaired-release">false</property>
                        <property name="activate-on-single-click">true</property>
                        <property name="column-spacing">16</property>
                        <property name="homogeneous">false</property>
                        <property name="max-children-per-line">4</property>
                        <property name="min-children-per-line">0</property>
                        <property name="row-spacing">16</property>
                        <property name="selection-mode">none</property>
                        <property name="valign">start</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>

                        <child>
                          <object class="GtkFlowBoxChild">
                            <property name="child">
                              <object class="GtkFrame" id="pkgbuild_card_template">
                                <property name="css-classes">quick-card pkgbuild-card</property>
                                <property name="margin-bottom">4</property>
                                <property name="margin-end">4</property>
                                <property name="margin-start">4</property>
                                <property name="margin-top">4</property>
                                <property name="width-request">220</property>
                                <property name="height-request">300</property>
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="margin-bottom">12</property>
                                    <property name="margin-end">12</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-top">12</property>
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">12</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkImage" id="pkgbuild_icon">
                                            <property name="icon-name">text-x-generic-symbolic</property>
                                            <property name="pixel-size">32</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkBox" id="trust_container">
                                            <property name="halign">end</property>
                                            <property name="hexpand">true</property>
                                            <property name="spacing">4</property>
                                            <child>
                                              <object class="GtkImage" id="trust_icon">
                                                <property name="pixel-size">16</property>
                                                <property name="tooltip-text" translatable="yes">Trust level indicator</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel" id="trust_label">
                                                <property name="ellipsize">end</property>
                                                <style>
                                                  <class name="caption"/>
                                                  <class name="dim-label"/>
                                                </style>
                                                <property name="tooltip-text" translatable="yes">AUR trust level (votes, update time, comments)</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="pkgbuild_name">
                                        <property name="ellipsize">end</property>
                                        <property name="justify">center</property>
                                        <property name="max-width-chars">20</property>
                                        <property name="wrap">true</property>
                                        <property name="wrap-mode">word-char</property>
                                        <attributes>
                                          <attribute name="weight" value="bold"/>
                                        </attributes>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="pkgbuild_version">
                                        <property name="ellipsize">end</property>
                                        <property name="justify">center</property>
                                        <property name="wrap">false</property>
                                        <style>
                                          <class name="caption"/>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="margin-top">8</property>
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">6</property>
                                        <child>
                                          <object class="GtkButton" id="build_button">
                                            <property name="css-classes">suggested-action pill</property>
                                            <property name="label" translatable="yes">Compile Package</property>
                                            <property name="tooltip-text" translatable="yes">Compile the PKGBUILD into an installable package</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkButton" id="edit_button">
                                            <property name="label" translatable="yes">Edit PKGBUILD</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="pill"/>
                                            </style>
                                            <property name="tooltip-text" translatable="yes">Open the PKGBUILD file in your default editor</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkButton" id="dependencies_button">
                                            <property name="label" translatable="yes">View Dependencies</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="pill"/>
                                            </style>
                                            <property name="tooltip-text" translatable="yes">Show the package dependencies</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkFlowBoxChild">
                            <property name="child">
                              <object class="GtkFrame" id="empty_card_template">
                                <property name="css-classes">quick-card empty-card</property>
                                <property name="margin-bottom">4</property>
                                <property name="margin-end">4</property>
                                <property name="margin-start">4</property>
                                <property name="margin-top">4</property>
                                <property name="width-request">220</property>
                                <property name="height-request">300</property>
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="halign">center</property>
                                    <property name="margin-bottom">24</property>
                                    <property name="margin-end">24</property>
                                    <property name="margin-start">24</property>
                                    <property name="margin-top">24</property>
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">16</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkImage" id="empty_icon">
                                        <property name="icon-name">folder-symbolic</property>
                                        <property name="opacity">0.5</property>
                                        <property name="pixel-size">48</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="justify">center</property>
                                        <property name="label" translatable="yes">This folder is empty</property>
                                        <property name="wrap">true</property>
                                        <property name="wrap-mode">word-char</property>
                                        <attributes>
                                          <attribute name="weight" value="bold"/>
                                        </attributes>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="download_pkgbuild_button">
                                        <property name="css-classes">suggested-action pill</property>
                                        <property name="label" translatable="yes">Download PKGBUILD</property>
                                        <property name="tooltip-text" translatable="yes">Download a PKGBUILD from AUR</property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="AdwViewStackPage">
                <property name="name">list</property>
                <property name="title" translatable="yes">List View</property>
                <property name="child">
                  <object class="GtkScrolledWindow" id="list_scrolled_content">
                    <property name="hscrollbar-policy">automatic</property>
                    <property name="vexpand">true</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <child>
                      <object class="GtkListBox" id="content_listbox">
                        <property name="selection-mode">none</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <style>
                          <class name="boxed-list"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="terminal_area">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="visible">false</property>
            <property name="margin-top">12</property>
            <property name="margin-bottom">12</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <style>
              <class name="terminal-box"/>
              <class name="view-section"/>
            </style>

            <child>
              <object class="GtkBox" id="terminal_toolbar">
                <property name="spacing">6</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-top">6</property>

                <child>
                  <object class="GtkLabel" id="terminal_label">
                    <property name="label" translatable="yes">Terminal Output</property>
                    <property name="halign">start</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                    </attributes>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="halign">end</property>
                    <property name="hexpand">true</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkToggleButton" id="autoscroll_toggle">
                        <property name="label" translatable="yes">Auto-scroll</property>
                        <property name="active">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                        <property name="tooltip-text" translatable="yes">Automatically scroll to the bottom of the terminal output</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="clear_terminal_button">
                        <property name="label" translatable="yes">Clear</property>
                        <style>
                          <class name="flat"/>
                        </style>
                        <property name="tooltip-text" translatable="yes">Clear the terminal output</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="hide_terminal_button">
                        <property name="label" translatable="yes">Hide</property>
                        <style>
                          <class name="flat"/>
                        </style>
                        <property name="tooltip-text" translatable="yes">Hide the terminal output panel</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkDropDown" id="detail_level_dropdown">
                        <property name="model">
                          <object class="GtkStringList">
                            <items>
                              <item translatable="yes">Minimum Detail</item>
                              <item translatable="yes">Standard Detail</item>
                              <item translatable="yes">Maximum Detail</item>
                            </items>
                          </object>
                        </property>
                        <property name="selected">1</property>
                        <property name="tooltip-text" translatable="yes">Select the level of detail for terminal output</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow" id="terminal_scrolled_window">
                <property name="hscrollbar-policy">automatic</property>
                <property name="vexpand">true</property>
                <property name="vscrollbar-policy">automatic</property>
                <property name="height-request">200</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-bottom">12</property>
                <child>
                  <object class="GtkTextView" id="terminal_output_view">
                    <property name="bottom-margin">8</property>
                    <property name="cursor-visible">false</property>
                    <property name="editable">false</property>
                    <property name="left-margin">8</property>
                    <property name="monospace">true</property>
                    <property name="right-margin">8</property>
                    <property name="top-margin">8</property>
                    <property name="wrap-mode">word</property>
                    <style>
                      <class name="terminal-view"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

          </object>
        </property>
        <child type="bottom">
          <object class="GtkActionBar" id="status_bar">
            <child type="start">
              <object class="GtkLabel" id="file_count_label">
                <property name="halign">start</property>
                <property name="hexpand">true</property>
                <property name="label" translatable="yes">0 files found</property>
                <style>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
            <child type="center">
              <object class="GtkLabel" id="selected_count_label">
                <property name="label" translatable="yes">No files selected</property>
                <property name="visible">false</property>
                <style>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
            <child type="end">
              <object class="GtkLabel" id="status_message_label">
                <property name="halign">end</property>
                <property name="label" translatable="yes">Ready</property>
                <style>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>

