<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="UpstreamUpdateCard" parent="GtkFrame">
    <property name="css-classes">
      <item>card</item>
      <item>upstream-update-card</item>
    </property>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="width-request">220</property>
    <property name="height-request">300</property>
    <property name="child">
      <object class="GtkBox">
        <property name="margin-bottom">12</property>
        <property name="margin-end">12</property>
        <property name="margin-start">12</property>
        <property name="margin-top">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">8</property>
            <child>
              <object class="GtkImage">
                <property name="icon-name">software-update-available-symbolic</property>
                <property name="pixel-size">32</property>
                <style>
                  <class name="success-color"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="hexpand">true</property>
                <property name="label" translatable="yes">New Upstream Version!</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
                <style><class name="heading"/></style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="package_name_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="max-width-chars">20</property>
            <property name="wrap">true</property>
            <property name="wrap-mode">word-char</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style><class name="heading"/></style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="aur_version_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="wrap">false</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
            <property name="label" translatable="yes">AUR: N/A</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="upstream_version_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="wrap">false</property>
            <style>
              <class name="caption"/>
              <class name="success-color"/>
              <class name="bold"/>
            </style>
            <property name="label" translatable="yes">Upstream: N/A</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="source_url_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="wrap">true</property>
            <property name="wrap-mode">word-char</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
            <property name="label" translatable="yes">Source: N/A</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="release_info_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="wrap">false</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
            <property name="label" translatable="yes">Released: N/A</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="cve_fix_label">
            <property name="ellipsize">end</property>
            <property name="justify">center</property>
            <property name="wrap">true</property>
            <property name="wrap-mode">word-char</property>
            <style>
              <class name="caption"/>
              <class name="error-color"/>
              <class name="bold"/>
            </style>
            <property name="label" translatable="yes">CVE Fix: N/A</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="margin-top">8</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="update_button">
                <property name="css-classes">
                  <item>suggested-action</item>
                  <item>pill</item>
                </property>
                <property name="label" translatable="yes">Update Now</property>
                <property name="tooltip-text" translatable="yes">Update to the new upstream version directly.</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="update_sandbox_button">
                <property name="label" translatable="yes">Update with Sandboxing</property>
                <style><class name="flat"/><class name="pill"/></style>
                <property name="tooltip-text" translatable="yes">Update in an isolated environment for increased security.</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="view_changelog_button">
                <property name="label" translatable="yes">View Changelog</property>
                <style><class name="flat"/><class name="pill"/></style>
                <property name="tooltip-text" translatable="yes">Open the upstream changelog for details.</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="ignore_version_button">
                <property name="label" translatable="yes">Ignore This Version</property>
                <style><class name="flat"/><class name="pill"/></style>
                <property name="tooltip-text" translatable="yes">Do not show alerts for this specific upstream version.</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
