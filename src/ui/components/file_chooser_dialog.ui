<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <!-- As propriedades de janela (modal, default-width, etc.) serão definidas no código Python para AdwDialog,
       já que Cambalache/Gtk.Builder pode ter problemas com elas no template diretamente. -->
  <template class="FileChooserDialog" parent="AdwDialog">
    <property name="title" translatable="yes">Select Folder with Compatible Files</property>
    <!-- O AdwDialog cria seu próprio AdwHeaderBar por padrão.
         Propriedades como 'show-title-buttons' são do AdwHeaderBar interno.
         'modal', 'default-width', 'default-height', 'resizable' serão setadas via Python. -->

    <!-- Conteúdo principal do diálogo, dentro de um único 'child' -->
    <child>
      <object class="GtkBox" id="main_box">
        <property name="orientation">vertical</property>
        <property name="spacing">18</property>
        <property name="margin-top">18</property>
        <property name="margin-bottom">18</property>
        <property name="margin-start">24</property>
        <property name="margin-end">24</property>
        <property name="vexpand">True</property> <!-- Adicionado para o box principal expandir -->
        <property name="hexpand">True</property> <!-- Adicionado para o box principal expandir -->

        <!-- Path navigation bar -->
        <child>
          <object class="GtkBox" id="path_bar">
            <property name="spacing">12</property>
            <property name="margin-bottom">12</property>

            <!-- Up button -->
            <child>
              <object class="GtkButton" id="up_button">
                <property name="icon-name">go-up-symbolic</property>
                <property name="tooltip-text" translatable="yes">Go up one level</property>
                <signal name="clicked" handler="on_up_button_clicked"/>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                </style>
              </object>
            </child>

            <!-- Current path display -->
            <child>
              <object class="GtkLabel" id="current_path_label">
                <property name="halign">start</property>
                <property name="hexpand">True</property>
                <property name="ellipsize">middle</property>
                <property name="max-width-chars">50</property>
                <property name="label">/home/user</property>
                <style>
                  <class name="monospace"/>
                  <class name="dim-label"/>
                </style>
                <property name="tooltip-text" translatable="yes">Current directory path.</property>
              </object>
            </child>

            <!-- Search entry -->
            <child>
              <object class="GtkSearchEntry" id="search_entry">
                <property name="placeholder-text" translatable="yes">Search files...</property>
                <property name="width-request">250</property>
                <signal name="search-changed" handler="on_search_entry_changed"/>
                <style>
                  <class name="rounded"/>
                </style>
                <property name="tooltip-text" translatable="yes">Filter files by name.</property>
              </object>
            </child>
          </object>
        </child>

        <!-- File grid container -->
        <child>
          <object class="GtkScrolledWindow" id="scrolled_window">
            <property name="vscrollbar-policy">automatic</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">True</property>
            <property name="hexpand">True</property>

            <!-- FlowBox for file cards -->
            <child>
              <object class="GtkFlowBox" id="files_grid">
                <property name="min-children-per-line">2</property>
                <property name="max-children-per-line">4</property>
                <property name="row-spacing">18</property>
                <property name="column-spacing">18</property>
                <property name="selection-mode">none</property>
                <property name="activate-on-single-click">True</property>
                <property name="homogeneous">False</property>
                <property name="valign">start</property>
                <property name="margin-start">6</property>
                <property name="margin-end">6</property>
                <property name="margin-top">6</property>
                <property name="margin-bottom">6</property>
                <signal name="child-activated" handler="on_file_activated"/>
              </object>
            </child>
          </object>
        </child>

        <!-- Status bar -->
        <child>
          <object class="GtkBox" id="status_bar">
            <property name="spacing">12</property>
            <property name="margin-top">12</property>

            <!-- File count -->
            <child>
              <object class="GtkLabel" id="file_count_label">
                <property name="halign">start</property>
                <property name="hexpand">True</property>
                <property name="label" translatable="yes">0 files found</property>
                <style>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>

            <!-- File type filters -->
            <child>
              <object class="GtkBox" id="filter_buttons">
                <property name="spacing">8</property>

                <child>
                  <object class="GtkToggleButton" id="filter_pkgbuild">
                    <property name="label" translatable="yes">PKGBUILD</property>
                    <property name="active">True</property>
                    <property name="name">PKGBUILD</property>
                    <signal name="toggled" handler="on_filter_toggled"/>
                    <style>
                      <class name="filter-button"/>
                      <class name="pill"/>
                    </style>
                    <property name="tooltip-text" translatable="yes">Show PKGBUILD files.</property>
                  </object>
                </child>

                <child>
                  <object class="GtkToggleButton" id="filter_packages">
                    <property name="label" translatable="yes">Packages</property>
                    <property name="active">True</property>
                    <property name="name">PACKAGE</property>
                    <signal name="toggled" handler="on_filter_toggled"/>
                    <style>
                      <class name="filter-button"/>
                      <class name="pill"/>
                    </style>
                    <property name="tooltip-text" translatable="yes">Show pre-compiled package files (.pkg.tar.zst).</property>
                  </object>
                </child>

                <child>
                  <object class="GtkToggleButton" id="filter_patches">
                    <property name="label" translatable="yes">Patches</property>
                    <property name="active">True</property>
                    <property name="name">PATCH</property>
                    <signal name="toggled" handler="on_filter_toggled"/>
                    <style>
                      <class name="filter-button"/>
                      <class name="pill"/>
                    </style>
                    <property name="tooltip-text" translatable="yes">Show patch files (.patch, .diff).</property>
                  </object>
                </child>

                <child>
                  <object class="GtkToggleButton" id="filter_advanced">
                    <property name="label" translatable="yes">Advanced</property>
                    <property name="active">True</property>
                    <property name="name">ADVANCED</property>
                    <signal name="toggled" handler="on_filter_toggled"/>
                    <style>
                      <class name="filter-button"/>
                      <class name="pill"/>
                    </style>
                    <property name="tooltip-text" translatable="yes">Show other compatible files and advanced options.</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Action area: Direto no box principal -->
        <child>
          <object class="GtkBox" id="action_area">
            <property name="orientation">horizontal</property>
            <property name="spacing">12</property>
            <property name="margin-bottom">18</property>
            <property name="margin-end">24</property>
            <property name="margin-start">24</property>
            <property name="margin-top">12</property> <!-- Adicionado margem superior para espaçamento -->
            <property name="halign">end</property>

            <child>
              <object class="GtkButton" id="cancel_button">
                <property name="label" translatable="yes">Cancel</property>
                <signal name="clicked" handler="on_cancel_clicked"/>
              </object>
            </child>

            <child>
              <object class="GtkButton" id="open_button">
                <property name="label" translatable="yes">Open</property>
                <style>
                  <class name="suggested-action"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_open_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>

  <!-- Template para Card de Arquivo PKGBUILD -->
  <template class="PkgbuildCard" parent="GtkFrame">
    <property name="css-classes">
      <item>card</item>
      <item>pkgbuild-card</item>
    </property>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="width-request">220</property>
    <property name="height-request">300</property>
    <property name="hexpand">False</property>
    <property name="vexpand">False</property>
    <property name="child">
      <object class="GtkBox" id="card_container">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <!-- Header com ícone e confiança -->
        <child>
          <object class="GtkBox" id="header_box">
            <property name="spacing">8</property>

            <!-- Ícone do arquivo -->
            <child>
              <object class="GtkImage" id="file_icon">
                <property name="icon-size">4</property>
                <property name="icon-name">text-x-generic-symbolic</property>
                <property name="pixel-size">32</property>
              </object>
            </child>

            <!-- Indicador de confiança -->
            <child>
              <object class="GtkBox" id="trust_container">
                <property name="halign">end</property>
                <property name="hexpand">True</property>
                <property name="spacing">4</property>

                <child>
                  <object class="GtkImage" id="trust_icon">
                    <property name="icon-size">1</property>
                    <property name="pixel-size">16</property>
                    <property name="visible">True</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel" id="trust_label">
                    <property name="visible">True</property>
                    <property name="ellipsize">end</property>
                    <style>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Nome do pacote -->
        <child>
          <object class="GtkLabel" id="package_name_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">20</property>
            <property name="ellipsize">end</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>

        <!-- Versão -->
        <child>
          <object class="GtkLabel" id="version_label">
            <property name="wrap">False</property>
            <property name="justify">center</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Detalhes adicionais -->
        <child>
          <object class="GtkLabel" id="details_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">25</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Indicador de confiança detalhado -->
        <child>
          <object class="GtkBox" id="detailed_trust_box">
            <property name="spacing">4</property>
            <property name="halign">center</property>
            <property name="visible">True</property>

            <child>
              <object class="GtkLabel" id="trust_votes_label">
                <property name="label" translatable="yes">Votes: </property>
                <style>
                  <class name="caption"/>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="trust_update_label">
                <property name="label" translatable="yes">Updated: </property>
                <style>
                  <class name="caption"/>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="trust_pgp_label">
                <property name="label" translatable="yes">PGP: </property>
                <style>
                  <class name="caption"/>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
          </object>
        </child>

        <!-- Separator -->
        <child>
          <object class="GtkSeparator">
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
          </object>
        </child>

        <!-- Ações principais -->
        <child>
          <object class="GtkBox" id="actions_box">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>

            <!-- Compilar Pacote -->
            <child>
              <object class="GtkButton" id="build_button">
                <property name="label" translatable="yes">Compile Package</property>
                <style>
                  <class name="suggested-action"/>
                  <class name="small-button"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_build_clicked"/>
              </object>
            </child>
            <!-- Novo botão para compilação com sandboxing -->
            <child>
              <object class="GtkMenuButton" id="build_sandbox_button">
                <property name="label" translatable="yes">Compile with Sandboxing</property>
                <style>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Compile in an isolated environment with customizable security settings.</property>
                <property name="popover">
                  <object class="GtkPopover">
                    <property name="position">bottom</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <style>
                          <class name="popover-content"/>
                        </style>
                        <child>
                          <object class="GtkComboBoxText" id="pkgbuild_sandbox_level_combo">
                            <property name="valign">center</property>
                            <property name="hexpand">true</property>
                            <items>
                              <item translatable="yes" id="strict">Strict Isolation</item>
                              <item translatable="yes" id="medium">Medium Isolation (Recommended)</item>
                              <item translatable="yes" id="minimal">Minimal Isolation</item>
                            </items>
                            <property name="active">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="pkgbuild_sandbox_network_check">
                            <property name="label" translatable="yes">Enable network access</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="pkgbuild_sandbox_filesystem_check">
                            <property name="label" translatable="yes">Allow access to home directory</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="confirm_pkgbuild_sandbox_build">
                            <property name="label" translatable="yes">Start Compile</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="pill"/>
                              <class name="small-button"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <!-- Editar PKGBUILD -->
            <child>
              <object class="GtkButton" id="edit_button">
                <property name="label" translatable="yes">Edit PKGBUILD</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_edit_clicked"/>
              </object>
            </child>

            <!-- Ver Dependências -->
            <child>
              <object class="GtkButton" id="dependencies_button">
                <property name="label" translatable="yes">View Dependencies</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_dependencies_clicked"/>
              </object>
            </child>

            <!-- Baixar Fontes -->
            <child>
              <object class="GtkButton" id="sources_button">
                <property name="label" translatable="yes">Download Sources</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_sources_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>

  <!-- Template para Card de Arquivo Pacote (.zst) -->
  <template class="PackageCard" parent="GtkFrame">
    <property name="css-classes">
      <item>card</item>
      <item>package-card</item>
    </property>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="width-request">220</property>
    <property name="height-request">300</property>
    <property name="hexpand">False</property>
    <property name="vexpand">False</property>
    <property name="child">
      <object class="GtkBox" id="card_container">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <!-- Header com ícone e confiança -->
        <child>
          <object class="GtkBox" id="header_box">
            <property name="spacing">8</property>

            <!-- Ícone do arquivo -->
            <child>
              <object class="GtkImage" id="file_icon">
                <property name="icon-size">4</property>
                <property name="icon-name">package-x-generic</property>
                <property name="pixel-size">32</property>
              </object>
            </child>

            <!-- Status de assinatura -->
            <child>
              <object class="GtkBox" id="signature_container">
                <property name="halign">end</property>
                <property name="hexpand">True</property>
                <property name="spacing">4</property>

                <child>
                  <object class="GtkImage" id="signature_icon">
                    <property name="icon-size">1</property>
                    <property name="pixel-size">16</property>
                    <property name="visible">True</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel" id="signature_label">
                    <property name="visible">True</property>
                    <property name="ellipsize">end</property>
                    <style>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Nome do pacote -->
        <child>
          <object class="GtkLabel" id="package_name_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">20</property>
            <property name="ellipsize">end</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>

        <!-- Versão -->
        <child>
          <object class="GtkLabel" id="version_label">
            <property name="wrap">False</property>
            <property name="justify">center</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Detalhes adicionais -->
        <child>
          <object class="GtkLabel" id="details_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">25</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Separator -->
        <child>
          <object class="GtkSeparator">
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
          </object>
        </child>

        <!-- Ações principais -->
        <child>
          <object class="GtkBox" id="actions_box">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>

            <!-- Instalar Pacote -->
            <child>
              <object class="GtkButton" id="install_button">
                <property name="label" translatable="yes">Install Package</property>
                <style>
                  <class name="suggested-action"/>
                  <class name="small-button"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_install_clicked"/>
              </object>
            </child>
            <!-- Novo botão para instalação com sandboxing -->
            <child>
              <object class="GtkMenuButton" id="install_sandbox_button">
                <property name="label" translatable="yes">Install with Sandboxing</property>
                <style>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Install in an isolated environment with customizable security settings.</property>
                <property name="popover">
                  <object class="GtkPopover">
                    <property name="position">bottom</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <style>
                          <class name="popover-content"/>
                        </style>
                        <child>
                          <object class="GtkComboBoxText" id="package_sandbox_level_combo">
                            <property name="valign">center</property>
                            <property name="hexpand">true</property>
                            <items>
                              <item translatable="yes" id="strict">Strict Isolation</item>
                              <item translatable="yes" id="medium">Medium Isolation (Recommended)</item>
                              <item translatable="yes" id="minimal">Minimal Isolation</item>
                            </items>
                            <property name="active">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="package_sandbox_network_check">
                            <property name="label" translatable="yes">Enable network access</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="package_sandbox_filesystem_check">
                            <property name="label" translatable="yes">Allow access to home directory</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="confirm_package_sandbox_install">
                            <property name="label" translatable="yes">Start Install</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="pill"/>
                              <class name="small-button"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <!-- Ver Informações -->
            <child>
              <object class="GtkButton" id="info_button">
                <property name="label" translatable="yes">View Information</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_info_clicked"/>
              </object>
            </child>

            <!-- Verificar Assinatura -->
            <child>
              <object class="GtkButton" id="verify_button">
                <property name="label" translatable="yes">Verify Signature</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_verify_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>

  <!-- Template para Card de Arquivo Patch -->
  <template class="PatchCard" parent="GtkFrame">
    <property name="css-classes">
      <item>card</item>
      <item>patch-card</item>
    </property>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="width-request">220</property>
    <property name="height-request">300</property>
    <property name="hexpand">False</property>
    <property name="vexpand">False</property>
    <property name="child">
      <object class="GtkBox" id="card_container">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <!-- Header com ícone -->
        <child>
          <object class="GtkBox" id="header_box">
            <property name="spacing">8</property>

            <!-- Ícone do arquivo -->
            <child>
              <object class="GtkImage" id="file_icon">
                <property name="icon-size">4</property>
                <property name="icon-name">text-x-patch</property>
                <property name="pixel-size">32</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Nome do patch -->
        <child>
          <object class="GtkLabel" id="patch_name_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">20</property>
            <property name="ellipsize">end</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>

        <!-- Descrição -->
        <child>
          <object class="GtkLabel" id="description_label">
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">25</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Separator -->
        <child>
          <object class="GtkSeparator">
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
          </object>
        </child>

        <!-- Ações principais -->
        <child>
          <object class="GtkBox" id="actions_box">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>

            <!-- Aplicar Patch -->
            <child>
              <object class="GtkButton" id="apply_button">
                <property name="label" translatable="yes">Apply Patch</property>
                <style>
                  <class name="suggested-action"/>
                  <class name="small-button"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_apply_clicked"/>
              </object>
            </child>
            <!-- Novo botão para aplicação de patch com sandboxing -->
            <child>
              <object class="GtkMenuButton" id="apply_sandbox_button">
                <property name="label" translatable="yes">Apply with Sandboxing</property>
                <style>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Apply patch in an isolated environment with customizable security settings.</property>
                <property name="popover">
                  <object class="GtkPopover">
                    <property name="position">bottom</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <style>
                          <class name="popover-content"/>
                        </style>
                        <child>
                          <object class="GtkComboBoxText" id="patch_sandbox_level_combo">
                            <property name="valign">center</property>
                            <property name="hexpand">true</property>
                            <items>
                              <item translatable="yes" id="strict">Strict Isolation</item>
                              <item translatable="yes" id="medium">Medium Isolation (Recommended)</item>
                              <item translatable="yes" id="minimal">Minimal Isolation</item>
                            </items>
                            <property name="active">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="patch_sandbox_network_check">
                            <property name="label" translatable="yes">Enable network access</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="patch_sandbox_filesystem_check">
                            <property name="label" translatable="yes">Allow access to home directory</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="confirm_patch_sandbox_apply">
                            <property name="label" translatable="yes">Start Apply</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="pill"/>
                              <class name="small-button"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <!-- Pré-visualização -->
            <child>
              <object class="GtkButton" id="preview_button">
                <property name="label" translatable="yes">Preview Changes</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_preview_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>

  <!-- Template para Card Avançado -->
  <template class="AdvancedCard" parent="GtkFrame">
    <property name="css-classes">
      <item>card</item>
      <item>advanced-card</item>
    </property>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="width-request">220</property>
    <property name="height-request">300</property>
    <property name="hexpand">False</property>
    <property name="vexpand">False</property>
    <property name="child">
      <object class="GtkBox" id="card_container">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <!-- Header com ícone -->
        <child>
          <object class="GtkBox" id="header_box">
            <property name="spacing">8</property>

            <!-- Ícone do arquivo -->
            <child>
              <object class="GtkImage" id="file_icon">
                <property name="icon-size">4</property>
                <property name="icon-name">applications-engineering-symbolic</property>
                <property name="pixel-size">32</property>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="title_label">
                <property name="label" translatable="yes">Advanced Mode</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
                <style>
                  <class name="heading"/>
                </style>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="description_label">
            <property name="label" translatable="yes">Execute custom commands with advanced options</property>
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <property name="justify">center</property>
            <property name="max-width-chars">30</property>
            <style>
              <class name="caption"/>
              <class name="dim-label"/>
            </style>
          </object>
        </child>

        <!-- Separator -->
        <child>
          <object class="GtkSeparator">
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
          </object>
        </child>

        <!-- Ações principais -->
        <child>
          <object class="GtkBox" id="actions_box">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>

            <!-- Executar Comando Personalizado -->
            <child>
              <object class="GtkButton" id="custom_command_button">
                <property name="label" translatable="yes">Execute Custom Command</property>
                <style>
                  <class name="suggested-action"/>
                  <class name="small-button"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_custom_command_clicked"/>
              </object>
            </child>
            <!-- Novo botão para comandos com sandboxing -->
            <child>
              <object class="GtkMenuButton" id="custom_command_sandbox_button">
                <property name="label" translatable="yes">Execute Sandboxed Command</property>
                <style>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <property name="tooltip-text" translatable="yes">Run a custom command in an isolated environment with customizable security settings.</property>
                <property name="popover">
                  <object class="GtkPopover">
                    <property name="position">bottom</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <style>
                          <class name="popover-content"/>
                        </style>
                        <child>
                          <object class="GtkComboBoxText" id="advanced_sandbox_level_combo">
                            <property name="valign">center</property>
                            <property name="hexpand">true</property>
                            <items>
                              <item translatable="yes" id="strict">Strict Isolation</item>
                              <item translatable="yes" id="medium">Medium Isolation (Recommended)</item>
                              <item translatable="yes" id="minimal">Minimal Isolation</item>
                            </items>
                            <property name="active">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="advanced_sandbox_network_check">
                            <property name="label" translatable="yes">Enable network access</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="advanced_sandbox_filesystem_check">
                            <property name="label" translatable="yes">Allow access to home directory</property>
                            <property name="active">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="confirm_advanced_sandbox_command">
                            <property name="label" translatable="yes">Start Command</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="pill"/>
                              <class name="small-button"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <!-- Simular Ação (Dry Run) -->
            <child>
              <object class="GtkButton" id="dry_run_button">
                <property name="label" translatable="yes">Simulate Action (Dry Run)</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_dry_run_clicked"/>
              </object>
            </child>

            <!-- Consultar Documentação -->
            <child>
              <object class="GtkButton" id="documentation_button">
                <property name="label" translatable="yes">Consult Documentation</property>
                <style>
                  <class name="small-button"/>
                  <class name="flat"/>
                  <class name="pill"/>
                </style>
                <signal name="clicked" handler="on_documentation_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
