<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <!-- Widget para exibir quando a lista está vazia -->
  <object class="GtkBox" id="empty_state_box">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <property name="margin-top">24</property>
    <property name="margin-bottom">24</property>
    <property name="margin-start">24</property>
    <property name="margin-end">24</property>
    <property name="valign">center</property>
    <property name="halign">center</property>
    <style>
      <class name="dim-label"/>
    </style>

    <!-- Ícone -->
    <child>
      <object class="GtkImage" id="empty_icon">
        <property name="icon-size">large</property>
        <property name="icon-name">folder-symbolic</property>
        <property name="margin-bottom">12</property>
      </object>
    </child>

    <!-- Título -->
    <child>
      <object class="GtkLabel" id="empty_title_label">
        <property name="label" translatable="yes">Empty Folder</property>
        <attributes>
          <attribute name="weight" value="bold"/>
        </attributes>
        <style>
          <class name="title-2"/>
        </style>
      </object>
    </child>

    <!-- Descrição -->
    <child>
      <object class="GtkLabel" id="empty_description_label">
        <property name="label" translatable="yes">This folder is empty. Download a PKGBUILD from AUR or create a new one.</property>
        <property name="wrap">true</property>
        <property name="wrap-mode">word-char</property>
        <property name="justify">center</property>
        <property name="max-width-chars">40</property>
        <style>
          <class name="caption"/>
          <class name="dim-label"/>
        </style>
      </object>
    </child>

    <!-- Opções de Download -->
    <child>
      <object class="GtkBox" id="empty_options_box">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-top">12</property>

        <!-- Baixar PKGBUILD -->
        <child>
          <object class="GtkButton" id="download_pkgbuild_button">
            <property name="label" translatable="yes">Download PKGBUILD</property>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
        </child>

        <!-- Modo Construtor -->
        <child>
          <object class="GtkButton" id="builder_mode_button">
            <property name="label" translatable="yes">Builder Mode (Wizard)</property>
            <style>
               <class name="flat"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
