<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.14"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="PackageCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <style><class name="card"/></style>

    <child>
      <object class="GtkBox" id="card_header">
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkImage" id="file_icon">
            <property name="icon-name">package-x-generic</property>
            <property name="pixel-size">32</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkLabel" id="package_name_label">
                <property name="halign">start</property>
                <property name="ellipsize">end</property>
                <style><class name="heading"/></style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="version_label">
                <property name="halign">start</property>
                <property name="ellipsize">end</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="signature_container">
            <property name="spacing">4</property>
            <property name="valign">start</property>
            <child>
              <object class="GtkImage" id="signature_icon">
                <property name="pixel-size">16</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="signature_label">
                <style><class name="caption"/></style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkLabel" id="details_label">
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="wrap">true</property>
        <property name="xalign">0</property>
        <style><class name="caption"/><class name="dim-label"/></style>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="actions_box">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkButton" id="install_button">
            <property name="label" translatable="yes">Install Package</property>
            <signal name="clicked" handler="on_install_clicked" swapped="true"/>
            <style><class name="suggested-action"/><class name="pill"/></style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="info_button">
            <property name="label" translatable="yes">View Information</property>
            <signal name="clicked" handler="on_info_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="verify_button">
            <property name="label" translatable="yes">Verify Signature</property>
            <signal name="clicked" handler="on_verify_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkRevealer" id="progress_revealer">
        <property name="transition-type">slide-down</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkSpinner" id="operation_spinner">
                <property name="spinning">true</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="operation_status">
                <property name="label" translatable="yes">Processing...</property>
                <property name="hexpand">true</property>
                <property name="xalign">0</property>
                <property name="ellipsize">end</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="status_indicator">
        <property name="spacing">4</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-bottom">8</property>
        <property name="halign">center</property>
        <child>
          <object class="GtkImage" id="status_icon">
            <property name="icon-name">emblem-ok-symbolic</property>
            <property name="pixel-size">12</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="status_text">
            <property name="label" translatable="yes">Ready to install</property>
            <style><class name="caption"/><class name="dim-label"/></style>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
