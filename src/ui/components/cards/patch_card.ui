<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.14"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="PatchCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <style>
      <class name="card"/>
      <class name="patch-card"/>
    </style>

    <child>
      <object class="GtkBox" id="card_header">
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkImage" id="file_icon">
            <property name="icon-name">text-x-patch</property>
            <property name="pixel-size">32</property>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="status_container">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkLabel" id="patch_name_label">
                <property name="halign">start</property>
                <property name="ellipsize">end</property>
                <style><class name="heading"/></style>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="spacing">6</property>
                <child>
                  <object class="GtkLabel" id="patch_status_label">
                    <property name="label" translatable="yes">Ready to Apply</property>
                    <style><class name="caption"/><class name="success"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="patch_type_label">
                    <property name="label" translatable="yes">.patch file</property>
                    <style><class name="caption"/><class name="dim-label"/></style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkLabel" id="description_label">
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="wrap">true</property>
        <property name="justify">center</property>
        <property name="ellipsize">end</property>
        <style><class name="caption"/><class name="dim-label"/></style>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="patch_info_box">
        <property name="orientation">vertical</property>
        <property name="spacing">4</property>
        <property name="halign">center</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">8</property>
            <property name="halign">center</property>
            <child>
              <object class="GtkLabel" id="lines_changed_label">
                <property name="label">Lines: +0/-0</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="files_affected_label">
                <property name="label">Files: 0</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="patch_size_label">
            <property name="label">Size: 0 KB</property>
            <property name="halign">center</property>
            <style><class name="caption"/><class name="dim-label"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="actions_box">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <child>
          <object class="GtkButton" id="apply_button">
            <property name="label" translatable="yes">Apply Patch</property>
            <signal name="clicked" handler="on_apply_clicked" swapped="true"/>
            <style><class name="suggested-action"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="view_details_button">
            <property name="label" translatable="yes">View Patch Details</property>
            <signal name="clicked" handler="on_view_details_clicked" swapped="true"/>
            <style><class name="accent"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkMenuButton" id="apply_sandbox_button">
            <property name="label" translatable="yes">Apply with Sandbox</property>
            <style><class name="flat"/><class name="pill"/></style>
            <property name="popover">
              <object class="GtkPopover">
                <property name="position">bottom</property>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="max-content-height">400</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <style><class name="popover-content"/></style>

                        <child>
                          <object class="GtkLabel" id="sandbox_title">
                            <property name="label" translatable="yes">Sandbox Apply Configuration</property>
                            <property name="margin-bottom">6</property>
                            <style><class name="heading"/></style>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <child>
                              <object class="AdwComboRow" id="patch_sandbox_level_combo">
                                <property name="title" translatable="yes">Isolation Level</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Strict Isolation</item>
                                      <item translatable="yes">Medium Isolation</item>
                                      <item translatable="yes">Minimal Isolation</item>
                                    </items>
                                  </object>
                                </property>
                                <property name="selected">1</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="patch_sandbox_network_check">
                                <property name="title" translatable="yes">Enable network access</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="patch_sandbox_filesystem_check">
                                <property name="title" translatable="yes">Allow home directory access</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Apply Options</property>
                            <child>
                              <object class="AdwSwitchRow" id="backup_before_apply_check">
                                <property name="title" translatable="yes">Create backup before applying</property>
                                <property name="active">true</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="dry_run_first_check">
                                <property name="title" translatable="yes">Perform dry run first</property>
                                <property name="active">true</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="ignore_whitespace_check">
                                <property name="title" translatable="yes">Ignore whitespace changes</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="confirm_patch_sandbox_apply">
                            <property name="label" translatable="yes">Start Sandbox Apply</property>
                            <property name="margin-top">12</property>
                            <signal name="clicked" handler="on_sandbox_apply_execute" swapped="true"/>
                            <style><class name="suggested-action"/><class name="pill"/></style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="preview_button">
            <property name="label" translatable="yes">Preview Changes</property>
            <signal name="clicked" handler="on_preview_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="validate_button">
            <property name="label" translatable="yes">Validate Patch</property>
            <signal name="clicked" handler="on_validate_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="revert_button">
            <property name="label" translatable="yes">Revert Patch</property>
            <property name="sensitive">false</property>
            <signal name="clicked" handler="on_revert_clicked" swapped="true"/>
            <style><class name="destructive-action"/><class name="pill"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkRevealer" id="progress_revealer">
        <property name="transition-type">slide-down</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkSpinner" id="operation_spinner">
                <property name="spinning">true</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="operation_status">
                <property name="label" translatable="yes">Processing...</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

  </template>
</interface>
