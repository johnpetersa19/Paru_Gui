<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.14"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="PkgbuildCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <style>
      <class name="card"/>
      <class name="pkgbuild-card"/>
    </style>

    <child>
      <object class="GtkBox" id="card_header">
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkImage" id="file_icon">
            <property name="icon-name">text-x-generic-symbolic</property>
            <property name="pixel-size">32</property>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="trust_container">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkLabel" id="package_name_label">
                <property name="halign">start</property>
                <property name="ellipsize">end</property>
                <style><class name="heading"/></style>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="spacing">4</property>
                <child>
                  <object class="GtkImage" id="trust_icon">
                    <property name="pixel-size">16</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="trust_label">
                    <property name="ellipsize">end</property>
                    <style><class name="caption"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="version_label">
                    <property name="ellipsize">end</property>
                    <style><class name="caption"/><class name="dim-label"/></style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkLabel" id="details_label">
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="wrap">true</property>
        <property name="justify">center</property>
        <property name="ellipsize">end</property>
        <style><class name="caption"/><class name="dim-label"/></style>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="detailed_trust_box">
        <property name="spacing">4</property>
        <property name="halign">center</property>
        <property name="orientation">vertical</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">8</property>
            <property name="halign">center</property>
            <child>
              <object class="GtkLabel" id="trust_votes_label">
                <property name="label">Votes: N/A</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="trust_update_label">
                <property name="label">Updated: N/A</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="trust_pgp_label">
            <property name="label">PGP: Verified</property>
            <property name="halign">center</property>
            <style><class name="caption"/><class name="dim-label"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="actions_box">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <child>
          <object class="GtkButton" id="build_button">
            <property name="label" translatable="yes">Build Package</property>
            <signal name="clicked" handler="on_build_clicked" swapped="true"/>
            <style><class name="suggested-action"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="review_button">
            <property name="label" translatable="yes">Review PKGBUILD</property>
            <signal name="clicked" handler="on_review_pkgbuild_clicked" swapped="true"/>
            <style><class name="accent"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkMenuButton" id="build_sandbox_button">
            <property name="label" translatable="yes">Build with Sandbox</property>
            <style><class name="flat"/><class name="pill"/></style>
            <property name="popover">
              <object class="GtkPopover">
                <property name="position">bottom</property>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="max-content-height">400</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <style><class name="popover-content"/></style>

                        <child>
                          <object class="GtkLabel" id="sandbox_title">
                            <property name="label" translatable="yes">Sandbox Build Configuration</property>
                            <property name="margin-bottom">6</property>
                            <style><class name="heading"/></style>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <child>
                              <object class="AdwComboRow" id="pkgbuild_sandbox_level_combo">
                                <property name="title" translatable="yes">Isolation Level</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Strict Isolation</item>
                                      <item translatable="yes">Medium Isolation</item>
                                      <item translatable="yes">Minimal Isolation</item>
                                    </items>
                                  </object>
                                </property>
                                <property name="selected">1</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="pkgbuild_sandbox_network_check">
                                <property name="title" translatable="yes">Enable network access</property>
                                <property name="active">true</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="pkgbuild_sandbox_filesystem_check">
                                <property name="title" translatable="yes">Allow home directory access</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Build Options</property>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_skip_pgp_check">
                                <property name="title" translatable="yes">Skip PGP Signature Check</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_skip_checksum_check">
                                <property name="title" translatable="yes">Skip Checksum Verification</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwEntryRow" id="extra_makepkg_flags_entry">
                                <property name="title" translatable="yes">Extra flags</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_keep_src_check">
                                <property name="title" translatable="yes">Keep Source Files</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_no_sign_check">
                                <property name="title" translatable="yes">Do Not Sign Package</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="confirm_pkgbuild_sandbox_build">
                            <property name="label" translatable="yes">Start Sandbox Build</property>
                            <property name="margin-top">12</property>
                            <signal name="clicked" handler="on_sandbox_build_execute" swapped="true"/>
                            <style><class name="suggested-action"/><class name="pill"/></style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="edit_button">
            <property name="label" translatable="yes">Edit PKGBUILD</property>
            <signal name="clicked" handler="on_edit_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="dependencies_button">
            <property name="label" translatable="yes">View Dependencies</property>
            <signal name="clicked" handler="on_dependencies_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="sources_button">
            <property name="label" translatable="yes">Download Sources</property>
            <signal name="clicked" handler="on_sources_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkRevealer" id="progress_revealer">
        <property name="transition-type">slide-down</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkSpinner" id="operation_spinner">
                <property name="spinning">true</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="operation_status">
                <property name="label" translatable="yes">Processing...</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

  </template>
</interface>
