<?xml version="1.0" encoding="UTF-8"?>
<interface domain="paru-gui">
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.5"/>
  <object class="GtkBox" id="AdvancedCard">
    <style>
      <class name="card"/>
      <class name="advanced-card"/>
    </style>
    <property name="margin-bottom">4</property>
    <property name="margin-end">4</property>
    <property name="margin-start">4</property>
    <property name="margin-top">4</property>
    <property name="hexpand">False</property>
    <property name="vexpand">False</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkBox" id="main_container">
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>

        <child>
          <object class="GtkBox" id="navigation_header">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkBox" id="breadcrumb_container">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkButton" id="breadcrumb_main">
                    <property name="label" translatable="yes">Main</property>
                    <property name="tooltip-text" translatable="yes">Return to main application view</property>
                    <style>
                      <class name="flat"/>
                      <class name="breadcrumb"/>
                    </style>
                    <signal name="clicked" handler="on_breadcrumb_main_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_separator1">
                    <property name="label" translatable="yes">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="breadcrumb_content">
                    <property name="label" translatable="yes">Content</property>
                    <property name="tooltip-text" translatable="yes">Return to content selection</property>
                    <style>
                      <class name="flat"/>
                      <class name="breadcrumb"/>
                    </style>
                    <signal name="clicked" handler="on_breadcrumb_content_clicked"/>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_separator2">
                    <property name="label" translatable="yes">›</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="breadcrumb_current">
                    <property name="label" translatable="yes">Advanced</property>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkButton" id="back_button">
                <property name="icon-name">go-previous-symbolic</property>
                <property name="tooltip-text" translatable="yes">Return to simple mode</property>
                <style>
                  <class name="circular"/>
                  <class name="suggested-action"/>
                </style>
                <signal name="clicked" handler="on_back_to_simple_clicked"/>
              </object>
            </child>

            <child>
              <object class="GtkRevealer" id="progress_revealer">
                <property name="reveal-child">false</property>
                <property name="transition-type">slide-left</property>
                <property name="child">
                  <object class="GtkSpinner" id="operation_spinner">
                    <property name="spinning">false</property>
                    <property name="width-request">16</property>
                    <property name="height-request">16</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="card_container">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="margin-top">12</property>
            <property name="margin-bottom">12</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>

            <child>
              <object class="GtkBox" id="header_box">
                <property name="spacing">8</property>
                <property name="halign">center</property>
                <child>
                  <object class="GtkImage" id="file_icon">
                    <property name="icon-size">large</property>
                    <property name="icon-name">applications-engineering-symbolic</property>
                    <property name="pixel-size">32</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="title_label">
                    <property name="label" translatable="yes">Advanced Mode</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                    </attributes>
                    <style>
                      <class name="heading"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="description_label">
                <property name="label" translatable="yes">Execute custom commands with advanced options and enhanced control</property>
                <property name="wrap">True</property>
                <property name="wrap-mode">word-char</property>
                <property name="justify">center</property>
                <property name="max-width-chars">30</property>
                <style>
                  <class name="caption"/>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>

            <child>
              <object class="GtkInfoBar" id="warning_bar">
                <property name="message-type">warning</property>
                <property name="show-close-button">false</property>
                <property name="revealed">true</property>
                <child>
                  <object class="GtkLabel" id="warning_label">
                    <property name="label" translatable="yes">Advanced mode allows dangerous operations. Use with caution.</property>
                    <property name="wrap">true</property>
                    <property name="max-width-chars">25</property>
                    <style>
                      <class name="caption"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkSeparator">
                <property name="margin-top">4</property>
                <property name="margin-bottom">4</property>
              </object>
            </child>

            <child>
              <object class="GtkBox" id="actions_box">
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>

                <child>
                  <object class="GtkButton" id="custom_command_button">
                    <property name="label" translatable="yes">Execute Custom Command</property>
                    <property name="tooltip-text" translatable="yes">Run a custom command with full system access - opens command dialog</property>
                    <signal name="clicked" handler="on_custom_command_clicked"/>
                    <style>
                      <class name="suggested-action"/>
                      <class name="small-button"/>
                      <class name="pill"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkMenuButton" id="custom_command_sandbox_button">
                    <property name="label" translatable="yes">Execute Sandboxed Command</property>
                    <property name="tooltip-text" translatable="yes">Run a custom command in an isolated environment with customizable security settings</property>
                    <style>
                      <class name="flat"/>
                      <class name="pill"/>
                    </style>
                    <property name="popover">
                      <object class="GtkPopover">
                        <property name="position">bottom</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">8</property>
                            <property name="margin-top">12</property>
                            <property name="margin-bottom">12</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>
                            <style>
                              <class name="popover-content"/>
                            </style>

                            <child>
                              <object class="GtkLabel" id="sandbox_title">
                                <property name="label" translatable="yes">Sandbox Configuration</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>

                            <child>
                              <object class="AdwComboRow" id="advanced_sandbox_level_combo">
                                <property name="title" translatable="yes">Isolation Level</property>
                                <property name="subtitle" translatable="yes">Choose security isolation level for command execution</property>
                                <property name="selected">1</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Strict Isolation</item>
                                      <item translatable="yes">Medium Isolation (Recommended)</item>
                                      <item translatable="yes">Minimal Isolation</item>
                                    </items>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="advanced_sandbox_network_check">
                                <property name="label" translatable="yes">Enable network access</property>
                                <property name="tooltip-text" translatable="yes">Allow the sandboxed command to access network resources</property>
                                <property name="active">false</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="advanced_sandbox_filesystem_check">
                                <property name="label" translatable="yes">Allow access to home directory</property>
                                <property name="tooltip-text" translatable="yes">Grant read/write access to user home directory</property>
                                <property name="active">false</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkSeparator">
                                <property name="margin-top">4</property>
                                <property name="margin-bottom">4</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="sandbox_skip_pgp_check">
                                <property name="label" translatable="yes">Skip PGP Check</property>
                                <property name="tooltip-text" translatable="yes">Bypass PGP signature verification - WARNING: reduces security</property>
                                <property name="active">False</property>
                                <style>
                                  <class name="warning"/>
                                </style>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="sandbox_skip_checksum_check">
                                <property name="label" translatable="yes">Skip Checksums</property>
                                <property name="tooltip-text" translatable="yes">Bypass file checksum verification - WARNING: reduces security</property>
                                <property name="active">False</property>
                                <style>
                                  <class name="warning"/>
                                </style>
                              </object>
                            </child>

                            <child>
                              <object class="GtkEntry" id="extra_makepkg_flags_entry">
                                <property name="text"></property>
                                <property name="placeholder-text" translatable="yes">Extra makepkg flags (e.g., --skippgpcheck --keepsrc)</property>
                                <property name="tooltip-text" translatable="yes">Add custom makepkg flags - separate multiple flags with spaces</property>
                                <property name="margin-top">6</property>
                                <property name="margin-bottom">6</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="sandbox_keep_src_check">
                                <property name="label" translatable="yes">Keep Sources (--keepsrc)</property>
                                <property name="tooltip-text" translatable="yes">Preserve source files after successful build completion</property>
                                <property name="active">False</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkCheckButton" id="sandbox_no_sign_check">
                                <property name="label" translatable="yes">Skip Package Signing (--nosign)</property>
                                <property name="tooltip-text" translatable="yes">Do not sign the resulting package with GPG</property>
                                <property name="active">False</property>
                              </object>
                            </child>

                            <child>
                              <object class="AdwComboRow" id="gpg_key_combo">
                                <property name="title" translatable="yes">PGP Key ID</property>
                                <property name="subtitle" translatable="yes">Select GPG key for package signing operations</property>
                                <property name="selected">0</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Default GPG Key</item>
                                      <item translatable="yes">Auto-fetch from KeyServer</item>
                                      <item translatable="yes">Use Custom ID/Command</item>
                                    </items>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="confirm_advanced_sandbox_command">
                                <property name="label" translatable="yes">Start Sandboxed Command</property>
                                <property name="tooltip-text" translatable="yes">Execute the command with selected sandbox configuration</property>
                                <style>
                                  <class name="suggested-action"/>
                                  <class name="pill"/>
                                  <class name="small-button"/>
                                </style>
                                <signal name="clicked" handler="on_sandbox_command_execute"/>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="dry_run_button">
                    <property name="label" translatable="yes">Simulate Action (Dry Run)</property>
                    <property name="tooltip-text" translatable="yes">Preview command execution without making changes - safe testing mode</property>
                    <signal name="clicked" handler="on_dry_run_clicked"/>
                    <style>
                      <class name="small-button"/>
                      <class name="flat"/>
                      <class name="pill"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="documentation_button">
                    <property name="label" translatable="yes">Consult Documentation</property>
                    <property name="tooltip-text" translatable="yes">Open advanced mode documentation and usage examples</property>
                    <signal name="clicked" handler="on_documentation_clicked"/>
                    <style>
                      <class name="small-button"/>
                      <class name="flat"/>
                      <class name="pill"/>
                    </style>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="return_simple_button">
                    <property name="label" translatable="yes">Return to Simple Mode</property>
                    <property name="tooltip-text" translatable="yes">Switch back to simple mode with basic options</property>
                    <signal name="clicked" handler="on_return_to_simple_clicked"/>
                    <style>
                      <class name="destructive-action"/>
                      <class name="small-button"/>
                      <class name="pill"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
