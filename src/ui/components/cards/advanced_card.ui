<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.14"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="libadwaita" version="1.5"/>

  <template class="AdvancedCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <style>
      <class name="card"/>
      <class name="advanced-card"/>
    </style>

    <child>
      <object class="GtkBox" id="card_header">
        <property name="spacing">8</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkImage" id="file_icon">
            <property name="icon-name">applications-engineering-symbolic</property>
            <property name="pixel-size">32</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="title_label">
            <property name="label" translatable="yes">Advanced Mode</property>
            <property name="halign">start</property>
            <style><class name="heading"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkLabel" id="description_label">
        <property name="label" translatable="yes">Execute custom commands with advanced options and enhanced control</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-bottom">8</property>
        <property name="wrap">true</property>
        <property name="justify">center</property>
        <style><class name="caption"/><class name="dim-label"/></style>
      </object>
    </child>

    <child>
      <object class="AdwBanner" id="warning_bar">
        <property name="title" translatable="yes">Advanced mode allows dangerous operations. Use with caution.</property>
        <property name="revealed">true</property>
        <style><class name="warning"/></style>
      </object>
    </child>

    <child>
      <object class="GtkBox" id="actions_box">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>

        <child>
          <object class="GtkButton" id="custom_command_button">
            <property name="label" translatable="yes">Execute Custom Command</property>
            <property name="tooltip-text" translatable="yes">Run a custom command with full system access</property>
            <signal name="clicked" handler="on_custom_command_clicked" swapped="true"/>
            <style><class name="suggested-action"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkMenuButton" id="custom_command_sandbox_button">
            <property name="label" translatable="yes">Execute Sandboxed Command</property>
            <property name="tooltip-text" translatable="yes">Run in an isolated environment</property>
            <style><class name="flat"/><class name="pill"/></style>
            <property name="popover">
              <object class="GtkPopover">
                <property name="position">bottom</property>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="max-content-height">400</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <style><class name="popover-content"/></style>

                        <child>
                          <object class="GtkLabel" id="sandbox_title">
                            <property name="label" translatable="yes">Sandbox Configuration</property>
                            <property name="margin-bottom">6</property>
                            <style><class name="heading"/></style>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <child>
                              <object class="AdwComboRow" id="advanced_sandbox_level_combo">
                                <property name="title" translatable="yes">Isolation Level</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Strict Isolation</item>
                                      <item translatable="yes">Medium Isolation</item>
                                      <item translatable="yes">Minimal Isolation</item>
                                    </items>
                                  </object>
                                </property>
                                <property name="selected">1</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="advanced_sandbox_network_check">
                                <property name="title" translatable="yes">Enable network access</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="advanced_sandbox_filesystem_check">
                                <property name="title" translatable="yes">Allow home directory access</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Advanced Options</property>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_skip_pgp_check">
                                <property name="title" translatable="yes">Skip PGP Check</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_skip_checksum_check">
                                <property name="title" translatable="yes">Skip Checksums</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwEntryRow" id="extra_makepkg_flags_entry">
                                <property name="title" translatable="yes">Extra flags</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_keep_src_check">
                                <property name="title" translatable="yes">Keep Sources</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="sandbox_no_sign_check">
                                <property name="title" translatable="yes">Skip Package Signing</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwComboRow" id="gpg_key_combo">
                                <property name="title" translatable="yes">PGP Key</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Default GPG Key</item>
                                      <item translatable="yes">Auto-fetch</item>
                                      <item translatable="yes">Custom ID</item>
                                    </items>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="confirm_advanced_sandbox_command">
                            <property name="label" translatable="yes">Start Sandboxed Command</property>
                            <property name="margin-top">12</property>
                            <signal name="clicked" handler="on_sandbox_command_execute" swapped="true"/>
                            <style><class name="suggested-action"/><class name="pill"/></style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="dry_run_button">
            <property name="label" translatable="yes">Simulate Action</property>
            <signal name="clicked" handler="on_dry_run_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="documentation_button">
            <property name="label" translatable="yes">Consult Documentation</property>
            <signal name="clicked" handler="on_documentation_clicked" swapped="true"/>
            <style><class name="flat"/><class name="pill"/></style>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="return_simple_button">
            <property name="label" translatable="yes">Return to Simple Mode</property>
            <signal name="clicked" handler="on_return_to_simple_clicked" swapped="true"/>
            <style><class name="destructive-action"/><class name="pill"/></style>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkRevealer" id="progress_revealer">
        <property name="transition-type">slide-down</property>
        <child>
          <object class="GtkBox">
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkSpinner" id="operation_spinner">
                <property name="spinning">true</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="operation_status">
                <property name="label" translatable="yes">Processing...</property>
                <style><class name="caption"/><class name="dim-label"/></style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

  </template>
</interface>
