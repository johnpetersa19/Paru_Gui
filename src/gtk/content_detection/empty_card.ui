<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="EmptyCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">20</property>
    <property name="margin-start">30</property>
    <property name="margin-end">30</property>
    <property name="margin-top">20</property>
    <property name="margin-bottom">20</property>

    <!-- Cabeçalho -->
    <child>
      <object class="GtkBox">
        <property name="spacing">10</property>

        <child>
          <object class="GtkImage">
            <property name="icon-name">folder-new-symbolic</property>
            <property name="pixel-size">24</property>
            <property name="css-classes">accent</property>
          </object>
        </child>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Pasta Vazia Detectada</property>
            <property name="css-classes">title-3</property>
          </object>
        </child>
      </object>
    </child>

    <!-- Mensagem explicativa -->
    <child>
      <object class="GtkLabel">
        <property name="label" translatable="yes">Esta pasta está vazia. Você pode baixar um PKGBUILD do AUR para começar.</property>
        <property name="wrap">true</property>
        <property name="xalign">0</property>
        <property name="margin-bottom">15</property>
      </object>
    </child>

    <!-- Campo de busca -->
    <child>
      <object class="GtkBox" id="search_box">
        <property name="spacing">10</property>

        <child>
          <object class="GtkEntry" id="aur_search">
            <property name="placeholder-text" translatable="yes">Nome do pacote do AUR (ex: firefox)</property>
            <property name="hexpand">true</property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="search_button">
            <property name="icon-name">system-search-symbolic</property>
          </object>
        </child>
      </object>
    </child>

    <!-- Opções adicionais -->
    <child>
      <object class="GtkBox" id="options_box">
        <property name="spacing">10</property>
        <property name="margin-top">10</property>

        <child>
          <object class="GtkCheckButton" id="ssh_toggle">
            <property name="label" translatable="yes">Usar SSH</property>
          </object>
        </child>

        <child>
          <object class="GtkCheckButton" id="comments_toggle">
            <property name="label" translatable="yes">Mostrar comentários</property>
          </object>
        </child>
      </object>
    </child>

    <!-- Ação principal -->
    <child>
      <object class="GtkButton" id="download_button">
        <property name="label" translatable="yes">Baixar PKGBUILD</property>
        <property name="css-classes">suggested-action</property>
        <property name="sensitive">false</property>
      </object>
    </child>
  </template>
</interface>
