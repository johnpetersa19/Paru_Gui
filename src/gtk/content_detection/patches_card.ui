<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="PatchesCard" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">20</property>
    <property name="margin-start">30</property>
    <property name="margin-end">30</property>
    <property name="margin-top">20</property>
    <property name="margin-bottom">20</property>

    <!-- Cabeçalho com ícone -->
    <child>
      <object class="GtkBox">
        <property name="spacing">10</property>

        <child>
          <object class="GtkImage">
            <property name="icon-name">insert-patch-symbolic</property>
            <property name="pixel-size">24</property>
            <property name="css-classes">accent</property>
          </object>
        </child>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Patches Detectados</property>
            <property name="css-classes">title-3</property>
          </object>
        </child>
      </object>
    </child>

    <!-- Mensagem contextual -->
    <child>
      <object class="GtkLabel">
        <property name="label" translatable="yes">Foram encontrados patches que podem ser aplicados ao PKGBUILD ou fontes.</property>
        <property name="wrap">true</property>
        <property name="xalign">0</property>
        <property name="margin-bottom">10</property>
      </object>
    </child>

    <!-- Lista de patches -->
    <child>
      <object class="GtkScrolledWindow">
        <property name="vexpand">true</property>
        <property name="min-content-height">150</property>

        <child>
          <object class="GtkListBox" id="patches_list">
            <property name="selection-mode">none</property>
            <property name="css-classes">boxed-list</property>

            <!-- Modelo de item (será preenchido pela lógica) -->
            <child>
              <object class="GtkListBoxRow">
                <child>
                  <object class="AdwActionRow" id="patch_template">
                    <property name="title">nome-do-patch.patch</property>
                    <property name="subtitle">Descrição do patch (será preenchida dinamicamente)</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <!-- Ação principal -->
    <child>
      <object class="GtkButton" id="apply_patches">
        <property name="label" translatable="yes">Aplicar Patches</property>
        <property name="css-classes">suggested-action</property>
      </object>
    </child>

    <!-- Ações secundárias -->
    <child>
      <object class="GtkBox" id="secondary_actions">
        <property name="spacing">10</property>

        <child>
          <object class="GtkButton" id="view_patch">
            <property name="label" translatable="yes">Visualizar Patch</property>
            <property name="css-classes">flat</property>
            <property name="hexpand">true</property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="refresh_list">
            <property name="label" translatable="yes">Atualizar Lista</property>
            <property name="css-classes">flat</property>
            <property name="hexpand">true</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
