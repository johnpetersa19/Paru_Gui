{
    "id": "org.gnome.paru-gui",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "paru_gui",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=host",
        "--talk-name=org.freedesktop.PackageKit",
        "--system-talk-name=org.freedesktop.systemd1",
        "--filesystem=~/.cache/paru:rw",
        "--filesystem=~/.config/paru:rw",
        "--filesystem=/var/cache/pacman:ro",
        "--env=PATH=/app/bin:/usr/bin:/bin"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/share/info",
        "*.la",
        "*.a"
    ],
    "build-options": {
        "env": {
            "PIP_DISABLE_PIP_VERSION_CHECK": "1"
        }
    },
    "modules": [
        {
            "name": "paru_gui",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/johnpetersa19/Paru_Gui.git",
                    "branch": "main"
                }
            ]
        }
    ]
}
