{
  "id": "org.gnome.painel_paru",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "painel_paru",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--filesystem=home",
    "--filesystem=xdg-run/flatpak",
    "--filesystem=xdg-run/gvfs",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.DBus",
    "--own-name=org.gnome.painel_paru"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "painel_paru",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}