<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.painel_paru" path="/org/gnome/painel_paru/">
    <key name="editor" type="s">
      <default>gedit</default>
      <summary>Editor de texto padrão</summary>
    </key>
    <key name="auto-install" type="b">
      <default>false</default>
      <summary>Instalar após build</summary>
    </key>
    <key name="log-level" type="i">
      <default>2</default>
      <summary>Nível de log</summary>
    </key>
    <key name="dev-reload-ui" type="b">
      <default>false</default>
      <summary>Recarregar UI com Ctrl+R</summary>
    </key>
    <key name="build-dir" type="s">
      <default>build</default>
      <summary>Diretório de build</summary>
    </key>
    <!-- NOVAS CHAVES ADICIONADAS ABAIXO -->
    <key name="review-pkgbuild" type="b">
      <default>true</default>
      <summary>Revisar PKGBUILD antes do build</summary>
    </key>
    <key name="clean-after" type="b">
      <default>false</default>
      <summary>Limpar após build (paru --cleanafter)</summary>
    </key>
    <key name="skip-review" type="b">
      <default>false</default>
      <summary>Ignorar revisão do PKGBUILD</summary>
    </key>
    <key name="verbose-debug" type="b">
      <default>false</default>
      <summary>Mostrar warnings detalhados</summary>
      <description>Se verdadeiro, mostra warnings detalhados durante o build.</description>
    </key>
    <key name="install-debug" type="b">
      <default>false</default>
      <summary>Instalar pacotes de depuração</summary>
      <description>Se verdadeiro, instala versões de depuração dos pacotes.</description>
    </key>
    <key name="devel-mode" type="b">
      <default>false</default>
      <summary>Modo de desenvolvedor</summary>
      <description>Se verdadeiro, permite atualizar pacotes de desenvolvimento (ex: -git, -svn).</description>
    </key>
    <key name="ignored-packages" type="as">
      <default>[]</default>
      <summary>Pacotes ignorados</summary>
      <description>Lista de pacotes que devem ser ignorados durante atualizações.</description>
    </key>
  </schema>
</schemalist>