<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.gnome.paru-gui</id>
  
  <name>Paru GUI</name>
  <summary>Manage Arch User Repository (AUR) packages with ease and security</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer_name>John Peter</developer_name>
  
  <description>
    <p>
      Paru GUI provides a modern and secure graphical interface for Paru, a powerful Arch User Repository (AUR) helper.
    </p>
    <p>
      It is designed with security as a priority, offering features like sandboxed build environments, detailed PKGBUILD analysis, and signature verification to protect your system. The user-friendly interface simplifies the process of searching, building, and managing AUR packages, making it accessible for both new and experienced Arch Linux users.
    </p>
    <ul>
      <li>Visualize and review PKGBUILDs before building.</li>
      <li>Analyze package security and community trust levels.</li>
      <li>Build packages in an isolated sandbox environment using Bubblewrap.</li>
      <li>Verify package and source signatures with GPG.</li>
      <li>Manage dependencies and track action history.</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">org.gnome.paru-gui.desktop</launchable>
  <icon type="stock">org.gnome.paru-gui</icon>
  
  <releases>
    <release version="2.7.0" date="2025-09-29">
      <description>
        <p>Initial release of Paru GUI.</p>
      </description>
    </release>
  </releases>
  
  <content_rating type="oars-1.1" />
  
  <url type="homepage">https://github.com/johnpetersa19/Paru_Gui</url>
  <url type="bugtracker">https://github.com/johnpetersa19/Paru_Gui/issues</url>
  
</component>
